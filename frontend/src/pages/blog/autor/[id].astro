---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import JsonLD from '../../../components/seo/JsonLD.astro';
import Header from '../../../components/sections/Header.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import ArticleCard from '../../../components/blog/ArticleCard.astro';
import { AUTHORS, type Author } from '../../../data/blog';

export async function getStaticPaths() {
  return AUTHORS.map((author) => ({
    params: { id: author.id },
    props: { author },
  }));
}

interface Props {
  author: Author;
}
const { author } = Astro.props as Props;

const posts = (
  await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
)
  .filter((p) => p.data.author === author.id)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.saaslyvet.com';
const pageUrl = `${siteUrl}/blog/autor/${author.id}/`;
const isPerson = author.id === 'felipe-diaz';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': isPerson ? 'Person' : 'Organization',
    name: author.name,
    ...(isPerson ? { jobTitle: author.role } : {}),
    description: author.bio,
    url: pageUrl,
    ...(author.sameAs && author.sameAs.length ? { sameAs: author.sameAs } : {}),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: author.name, item: pageUrl },
  ],
};

const initials = author.name
  .split(' ')
  .slice(0, 2)
  .map((w) => w[0])
  .join('')
  .toUpperCase();
---

<Base
  title={`${author.name} — Autor en el blog | SaaslyVet`}
  description={author.bio}
  canonical={pageUrl}
  ogType="website"
  jsonld={personSchema}
>
  <Fragment slot="head">
    <JsonLD schema={breadcrumbSchema} />
    <link rel="alternate" type="application/rss+xml" title="Blog de SaaslyVet" href="/blog/rss.xml" />
  </Fragment>

  <Header />

  <main id="main" class="pt-16">
    <section class="border-b border-line bg-gradient-hero">
      <div class="container-wide py-12 lg:py-16">
        <Breadcrumbs
          items={[
            { label: 'Inicio', href: '/' },
            { label: 'Blog', href: '/blog/' },
            { label: author.name },
          ]}
        />

        <div class="mt-8 flex items-start gap-5">
          <span
            class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand/10 font-display text-xl font-semibold text-brand"
            aria-hidden="true"
          >
            {initials}
          </span>
          <div class="max-w-2xl">
            <p class="eyebrow">{author.role}</p>
            <h1 class="mt-2 font-display text-3xl font-semibold tracking-tight text-ink lg:text-4xl">
              {author.name}
            </h1>
            <p class="mt-4 text-lg leading-relaxed text-ink-secondary">{author.bio}</p>
          </div>
        </div>
      </div>
    </section>

    <div class="container-wide py-12 lg:py-16">
      <h2 class="mb-6 font-display text-xl font-semibold tracking-tight text-ink">
        {posts.length > 0 ? `Artículos de ${author.name}` : 'Sin artículos por ahora'}
      </h2>
      {
        posts.length > 0 ? (
          <div class="grid gap-px overflow-hidden rounded-2xl bg-line ring-1 ring-line sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((p, i) => (
              <ArticleCard post={p} index={i} />
            ))}
          </div>
        ) : (
          <p class="text-ink-secondary">
            Aún no hay artículos publicados con esta firma. Explora el{' '}
            <a href="/blog/" class="font-medium text-brand underline underline-offset-2 hover:text-brand-hover">blog</a>.
          </p>
        )
      }
    </div>
  </main>

  <Footer />
</Base>
