---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { readingTime } from '../../data/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );

  // Conjunto de todos los slugs (incl. borradores) para validar `related` en build.
  const allSlugs = new Set((await getCollection('blog')).map((p) => p.id));

  // Orden global por fecha (desc) para navegación anterior/siguiente.
  const sorted = [...posts].sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return sorted.map((entry, i) => {
    // En orden desc: i-1 es más reciente (Siguiente), i+1 más antiguo (Anterior).
    const next = sorted[i - 1]; // más reciente
    const prev = sorted[i + 1]; // más antiguo

    // Interlinking automático: `related` explícito (validado) o fallback por categoría.
    let related: typeof sorted;
    if (entry.data.related.length) {
      for (const slug of entry.data.related) {
        if (!allSlugs.has(slug)) {
          throw new Error(
            `[blog] "${entry.id}.md": related → "${slug}" no existe. Usa un slug de artículo válido.`
          );
        }
      }
      // Respeta el orden declarado; solo enlaza los ya publicados.
      related = entry.data.related
        .map((slug) => sorted.find((p) => p.id === slug))
        .filter((p): p is (typeof sorted)[number] => Boolean(p) && p!.id !== entry.id);
    } else {
      related = sorted.filter(
        (p) => p.id !== entry.id && p.data.category === entry.data.category
      );
    }
    related = related.slice(0, 3);

    return {
      params: { slug: entry.id },
      props: { entry, related, prev, next },
    };
  });
}

interface Props {
  entry: CollectionEntry<'blog'>;
  related: CollectionEntry<'blog'>[];
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { entry, related, prev, next } = Astro.props as Props;
const { Content, headings } = await render(entry);
const rt = readingTime(entry.body ?? '', entry.data.readingTimeOverride);
---

<BlogLayout post={entry} headings={headings} readingTime={rt} related={related} prev={prev} next={next}>
  <Content />
</BlogLayout>
