---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import JsonLD from '../../components/seo/JsonLD.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import CategoryNav from '../../components/blog/CategoryNav.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import CategoryIcon from '../../components/blog/CategoryIcon.astro';
import Pagination from '../../components/blog/Pagination.astro';
import Search from '../../components/icons/Search.astro';
import ArrowRight from '../../components/icons/ArrowRight.astro';
import { getCategory, readingTime, formatDate, isoDate, POSTS_PER_PAGE } from '../../data/blog';

const posts = (
  await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = featured ? posts.filter((p) => p.id !== featured.id) : posts;

// Página 1 del archivo; el resto se sirve en /blog/pagina/[page].
const pageItems = rest.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(rest.length / POSTS_PER_PAGE));

const featCat = featured ? getCategory(featured.data.category) : undefined;
const featRt = featured ? readingTime(featured.body ?? '', featured.data.readingTimeOverride) : 0;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.saaslyvet.com';
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog de SaaslyVet',
  description:
    'Guías prácticas sobre software y gestión veterinaria para dueños de clínicas: agenda, expediente, inventario, cobros, automatización y transformación digital.',
  url: `${siteUrl}/blog/`,
  inLanguage: 'es-MX',
  publisher: {
    '@type': 'Organization',
    name: 'SaaslyVet',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo-512.png` },
  },
};
---

<Base
  title="Blog de gestión y software veterinario | SaaslyVet"
  description="Guías prácticas para dueños de clínicas veterinarias: cómo gestionar la agenda, el expediente, el inventario, los cobros y crecer tu clínica con software y automatización."
  ogType="website"
>
  <Fragment slot="head">
    <JsonLD schema={blogSchema} />
    <link rel="alternate" type="application/rss+xml" title="Blog de SaaslyVet" href="/blog/rss.xml" />
  </Fragment>

  <Header />

  <main id="main" class="pt-16">
    <!-- Hero -->
    <section class="border-b border-line bg-gradient-hero">
      <div class="container-wide py-14 lg:py-20">
        <div class="max-w-3xl">
          <p class="eyebrow">Blog SaaslyVet</p>
          <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink text-balance lg:text-5xl">
            Ideas para gestionar y hacer crecer tu clínica veterinaria
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-secondary">
            Guías directas y sin relleno sobre software, agenda, expediente clínico, inventario,
            cobros, automatización y transformación digital. Escritas para el día a día de una clínica.
          </p>

          <!-- Buscador (índice JSON: busca sobre todos los artículos, no solo la página) -->
          <div class="mt-8 max-w-md">
            <label for="blog-search" class="sr-only">Buscar artículos</label>
            <div class="relative">
              <Search class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-tertiary" />
              <input
                id="blog-search"
                type="search"
                autocomplete="off"
                placeholder="Buscar artículos…"
                class="w-full rounded-full border border-line bg-surface py-3 pl-11 pr-4 text-sm text-ink placeholder:text-ink-tertiary transition-colors focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container-wide py-12 lg:py-16">
      <!-- Resultados de búsqueda (se rellenan por JS; ocultos por defecto) -->
      <div id="blog-results" hidden></div>

      <!-- Listado normal -->
      <div id="blog-listing">
        <div class="mb-10">
          <CategoryNav />
        </div>

        <!-- Artículo destacado (solo en la página 1) -->
        {
          featured && featCat && (
            <section class="mb-12">
              <p class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-ink-tertiary">Destacado</p>
              <article
                data-reveal="fade-up"
                class="group grid overflow-hidden rounded-2xl border border-line bg-surface lg:grid-cols-2"
              >
                <div class="relative flex min-h-[220px] items-center justify-center bg-gradient-primary p-8">
                  <div
                    class="absolute inset-0 opacity-[0.18]"
                    aria-hidden="true"
                    style="background-image: radial-gradient(circle at 20% 20%, hsl(158 40% 55%) 0%, transparent 45%), radial-gradient(circle at 85% 80%, hsl(16 75% 60%) 0%, transparent 45%)"
                  />
                  <CategoryIcon name={featCat.icon} class="relative h-16 w-16 text-white/90" />
                </div>
                <div class="flex flex-col justify-center p-8 lg:p-10">
                  <a
                    href={`/blog/categoria/${featCat.slug}/`}
                    class="relative z-10 text-xs font-semibold uppercase tracking-[0.14em] text-brand hover:text-brand-hover"
                  >
                    {featCat.name}
                  </a>
                  <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink text-balance lg:text-3xl">
                    <a href={`/blog/${featured.id}/`} class="transition-colors hover:text-brand">
                      {featured.data.title}
                    </a>
                  </h2>
                  <p class="mt-3 leading-relaxed text-ink-secondary">{featured.data.description}</p>
                  <div class="mt-5 flex items-center gap-3 text-xs text-ink-tertiary">
                    <time datetime={isoDate(featured.data.publishDate)}>{formatDate(featured.data.publishDate)}</time>
                    <span aria-hidden="true">·</span>
                    <span>{featRt} min de lectura</span>
                  </div>
                  <a
                    href={`/blog/${featured.id}/`}
                    class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-ink transition-colors hover:text-brand"
                  >
                    Leer artículo
                    <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                  </a>
                </div>
              </article>
            </section>
          )
        }

        <!-- Listado paginado -->
        <section>
          <h2 class="mb-6 font-display text-xl font-semibold tracking-tight text-ink">Últimos artículos</h2>

          {
            pageItems.length > 0 ? (
              <div class="grid gap-px overflow-hidden rounded-2xl bg-line ring-1 ring-line sm:grid-cols-2 lg:grid-cols-3">
                {pageItems.map((p, i) => (
                  <ArticleCard post={p} index={i} />
                ))}
              </div>
            ) : (
              <p class="text-ink-secondary">Muy pronto publicaremos más artículos. Vuelve en unos días.</p>
            )
          }

          <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
        </section>
      </div>
    </div>
  </main>

  <Footer />

  <script>
    const input = document.getElementById('blog-search') as HTMLInputElement | null;
    const results = document.getElementById('blog-results');
    const listing = document.getElementById('blog-listing');

    let index: any[] | null = null;
    async function loadIndex() {
      if (index) return index;
      try {
        const res = await fetch('/blog/search-index.json');
        index = await res.json();
      } catch {
        index = [];
      }
      return index;
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
      );
    }

    input?.addEventListener('input', async () => {
      const q = input.value.trim().toLowerCase();
      if (!results || !listing) return;

      if (!q) {
        results.hidden = true;
        results.innerHTML = '';
        listing.hidden = false;
        return;
      }

      const data = (await loadIndex()) || [];
      const matches = data.filter((p) => (p.search || '').includes(q)).slice(0, 20);

      listing.hidden = true;
      results.hidden = false;

      if (matches.length === 0) {
        results.innerHTML =
          '<p class="py-16 text-center text-ink-secondary">No encontramos artículos para tu búsqueda. Prueba con otra palabra.</p>';
        return;
      }

      const rows = matches
        .map(
          (m) => `
          <a href="${m.url}" class="group flex flex-col gap-1 border-b border-line py-5 first:border-t">
            <span class="text-xs font-semibold uppercase tracking-[0.14em] text-brand">${escapeHtml(m.category)}</span>
            <span class="font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-brand">${escapeHtml(m.title)}</span>
            <span class="text-sm leading-relaxed text-ink-secondary">${escapeHtml(m.description)}</span>
          </a>`
        )
        .join('');

      results.innerHTML =
        `<p class="mb-2 text-sm text-ink-tertiary">${matches.length} resultado(s)</p>` + rows;
    });
  </script>
</Base>
