---
import Base from '../layouts/Base.astro';
import ScrollProgress from '../components/animations/ScrollProgress.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import ProblemSolution from '../components/sections/ProblemSolution.astro';
import Features from '../components/sections/Features.astro';
import EmotionalBand from '../components/sections/EmotionalBand.astro';
import ProductTour from '../components/sections/ProductTour.astro';
import Automation from '../components/sections/Automation.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
import BlogTeaser from '../components/sections/BlogTeaser.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
---

<Base
  title="Software de gestión veterinaria para clínicas | SaaslyVet"
  description="El software de gestión veterinaria que centraliza agenda, expediente clínico, inventario y cobros, con recordatorios automáticos por WhatsApp. Sin instalaciones. Prueba 14 días gratis."
>
  <ScrollProgress />

  <Header />

  <main id="main">
    <Hero />
    <ProblemSolution />
    <EmotionalBand />
    <Features />
    <ProductTour />
    <Automation />
    <Pricing />
    <FAQ />
    <BlogTeaser />
    <FinalCTA />
  </main>

  <Footer />
</Base>
