---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  /** Imagen importada con astro:assets (no string suelto). */
  src: ImageMetadata;
  alt: string;
  /**
   * Difuminado de bordes vía mask-image:
   * - 'all': elipse radial, funde en todas direcciones (imágenes centradas/solas).
   * - 'sides': solo izquierda/derecha.
   * - 'top-bottom': solo arriba/abajo.
   * - 'top' | 'bottom': funde un solo borde.
   * - 'none': sin máscara (p. ej. foto de fondo donde un overlay hace la integración).
   */
  fade?: 'all' | 'sides' | 'top-bottom' | 'top' | 'bottom' | 'none';
  /** Qué tan agresivo es el fade. 'soft' conserva casi toda la imagen. */
  intensity?: 'soft' | 'medium' | 'strong';
  /** Ancho máximo del contenedor (cualquier unidad CSS). Ignorado si cover. */
  maxWidth?: string;
  /**
   * Modo fondo: la imagen llena el contenedor padre (object-cover) en vez de
   * escalar por su tamaño natural. Úsalo cuando el padre es absolute/inset.
   */
  cover?: boolean;
  /** object-position cuando cover (ej. 'center', 'center 30%'). */
  objectPosition?: string;
  /** Sombra suave que respeta los bordes difuminados (drop-shadow). */
  shadow?: boolean;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  fade = 'all',
  intensity = 'soft',
  maxWidth = '100%',
  cover = false,
  objectPosition = 'center',
  shadow = false,
  class: className = '',
  loading = 'lazy',
} = Astro.props;

// Stops de la elipse radial: [borde-sólido%, transparente%]
const radialStops = { soft: [74, 100], medium: [56, 94], strong: [40, 84] } as const;
// % difuminado en cada borde para los gradientes lineales
const edgeStops = { soft: 12, medium: 22, strong: 34 } as const;

const [inner, outer] = radialStops[intensity];
const edge = edgeStops[intensity];

let maskValue = '';
switch (fade) {
  case 'none':
    break;
  case 'sides':
    maskValue = `linear-gradient(to right, transparent 0, #000 ${edge}%, #000 ${100 - edge}%, transparent 100%)`;
    break;
  case 'top-bottom':
    maskValue = `linear-gradient(to bottom, transparent 0, #000 ${edge}%, #000 ${100 - edge}%, transparent 100%)`;
    break;
  case 'bottom':
    maskValue = `linear-gradient(to bottom, #000 ${100 - edge * 2}%, transparent 100%)`;
    break;
  case 'top':
    maskValue = `linear-gradient(to top, #000 ${100 - edge * 2}%, transparent 100%)`;
    break;
  case 'all':
  default:
    maskValue = `radial-gradient(ellipse at center, #000 ${inner}%, transparent ${outer}%)`;
    break;
}

const wrapperStyle = [
  cover ? null : `max-width:${maxWidth}`,
  shadow ? 'filter:drop-shadow(0 14px 24px rgba(20,40,35,0.16))' : null,
].filter(Boolean).join(';');

const maskStyle =
  (maskValue
    ? `-webkit-mask-image:${maskValue};mask-image:${maskValue};` +
      '-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;' +
      '-webkit-mask-size:100% 100%;mask-size:100% 100%;'
    : '') + (cover ? `object-position:${objectPosition};` : '');

const figureClass = cover ? 'fade-image m-0 h-full w-full' : 'fade-image m-0';
const imgClass = cover ? 'block h-full w-full object-cover' : 'block h-auto w-full';
---

<figure class:list={[figureClass, className]} style={wrapperStyle}>
  <Image
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
    class={imgClass}
    style={maskStyle}
  />
</figure>
