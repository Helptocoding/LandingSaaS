---
import X from '../icons/X.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const loginUrl = 'https://app.saaslyvet.com/login';
const password = 'DemoSaaSlyVet2026';
const users = [
  { role: 'Administrador', email: 'demo-admin@saaslyvet.com' },
  { role: 'Veterinario', email: 'demo-vet@saaslyvet.com' },
  { role: 'Recepción', email: 'demo-recepcion@saaslyvet.com' },
];
---

<div
  id="demo-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="demo-modal-title"
>
  <div data-demo-overlay class="absolute inset-0 bg-ink/60 backdrop-blur-sm"></div>

  <div class="animate-fade-up relative w-full max-w-md rounded-2xl bg-surface p-7 shadow-lift">
    <button
      data-demo-close
      aria-label="Cerrar"
      class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-lg text-ink-tertiary transition-colors hover:bg-muted hover:text-ink"
    >
      <X class="h-4 w-4" />
    </button>

    <span class="inline-flex items-center rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand">
      Demo gratuita
    </span>
    <h2 id="demo-modal-title" class="mt-3 font-display text-xl font-semibold tracking-tight text-ink">
      Entra a la demo de SaaslyVet
    </h2>
    <p class="mt-1.5 text-sm text-ink-secondary">
      Elige un usuario, copia la contraseña y abre el login. Datos de ejemplo, sin compromiso.
    </p>

    <!-- Contraseña -->
    <div class="mt-5">
      <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-ink-tertiary">Contraseña (para todos)</p>
      <div data-copy={password} class="mt-1.5 flex items-center justify-between gap-3 rounded-lg border border-line bg-muted/40 px-3 py-2.5">
        <code class="font-mono text-sm text-ink">{password}</code>
        <button data-copy-btn class="shrink-0 rounded-md px-2.5 py-1.5 text-xs font-semibold text-brand transition-colors hover:bg-brand/10">
          Copiar
        </button>
      </div>
    </div>

    <!-- Usuarios -->
    <div class="mt-4">
      <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-ink-tertiary">Usuarios demo</p>
      <div class="mt-1.5 space-y-2">
        {users.map((u) => (
          <div data-copy={u.email} class="flex items-center justify-between gap-3 rounded-lg border border-line bg-surface px-3 py-2.5">
            <div class="min-w-0">
              <p class="text-[11px] font-medium uppercase tracking-wider text-ink-tertiary">{u.role}</p>
              <code class="block truncate font-mono text-sm text-ink">{u.email}</code>
            </div>
            <button data-copy-btn class="shrink-0 rounded-md px-2.5 py-1.5 text-xs font-semibold text-brand transition-colors hover:bg-brand/10">
              Copiar
            </button>
          </div>
        ))}
      </div>
    </div>

    <a
      href={loginUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-md bg-ink px-5 py-3 text-sm font-semibold text-surface shadow-soft transition-colors hover:bg-ink/90"
    >
      Abrir login
      <ArrowRight class="h-4 w-4" />
    </a>
  </div>
</div>

<script>
  const modal = document.getElementById('demo-modal');
  if (modal) {
    const open = () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      modal.querySelector<HTMLElement>('a[href]')?.focus();
    };
    const close = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    };

    // Vía 1: evento despachado por cta.js (ctaToast('demo')).
    document.addEventListener('saaslyvet:demo', open);
    // Vía 2 (robusta, sin dependencias): delegación directa sobre cualquier CTA de demo.
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement)?.closest?.('[data-cta-kind="demo"]');
      if (trigger) {
        e.preventDefault();
        open();
      }
    });

    modal
      .querySelectorAll<HTMLElement>('[data-demo-close], [data-demo-overlay]')
      .forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });

    modal.querySelectorAll<HTMLElement>('[data-copy-btn]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest<HTMLElement>('[data-copy]');
        const value = row?.getAttribute('data-copy') ?? '';
        try {
          await navigator.clipboard.writeText(value);
        } catch {
          /* clipboard bloqueado: sin feedback, el texto sigue visible */
        }
        const prev = btn.textContent;
        btn.textContent = 'Copiado';
        window.setTimeout(() => {
          btn.textContent = prev;
        }, 1400);
      });
    });
  }
</script>
