---
import { Image } from 'astro:assets';
import Check from '../icons/Check.astro';
import WhatsApp from '../icons/WhatsApp.astro';
import CalendarCheck2 from '../icons/CalendarCheck2.astro';
import MarketingDashboard from '../marketing/MarketingDashboard.astro';
import tabletFrame from '../../assets/img/hero_tablet_frame.png';

/*
  Área visible de la pantalla dentro del WebP del marco (medida sobre el PNG
  original 1536×1024, en % del propio marco). El MarketingDashboard se renderiza
  detrás y se recorta exactamente a este rectángulo; el marco va encima.
    left 20.83% · top 14.84% · width 64.78% · height 68.26%  (relación 995/699)
*/
---

<div id="hero-control" class="hero-mockup relative mx-auto w-full max-w-[560px] lg:max-w-[620px] xl:max-w-[680px]">

  <!-- ── Iluminación ambiental: todo por CSS, el WebP se mantiene transparente ── -->
  <div class="hero-ambient pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <span class="hero-glow hero-glow--primary"></span>
    <span class="hero-glow hero-glow--accent"></span>
    <span class="hero-glow hero-glow--soft"></span>
    <span class="hero-glow hero-ground"></span>
  </div>

  <!-- ── Tablet: dashboard vivo (HTML) + marco (WebP) + reflejo (CSS) ── -->
  <div class="hero-tablet__float">
    <div class="hero-tablet">

      <!-- Pantalla: el componente real, recortado al área visible -->
      <div class="hero-tablet__screen">
        <div class="hero-tablet__scale">
          <MarketingDashboard variant="hero" animated={false} compact={true} />
        </div>
      </div>

      <!-- Marco físico encima (bisel, cámara, manos). Pantalla transparente. -->
      <Image
        src={tabletFrame}
        alt="Tablet mostrando el panel de SaaSlyVet con la agenda, ingresos y pacientes de una clínica veterinaria"
        widths={[420, 620, 840, 1200, 1536]}
        sizes="(max-width: 1023px) 88vw, 620px"
        format="webp"
        quality={82}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero-tablet__frame"
        draggable="false"
      />
    </div>
  </div>

  <!-- ── Tarjetas flotantes: WhatsApp + Agenda ── -->

  <!-- WhatsApp (wsp) — esquina superior derecha, flota hacia arriba -->
  <div
    id="hcc-signal-wa"
    class="hcc-signal pointer-events-none absolute right-1 top-3 z-20 md:-right-3 md:top-6
           hidden md:flex items-center gap-2 rounded-full border border-line bg-white/95 px-3 py-2 backdrop-blur-sm"
  >
    <WhatsApp class="h-3.5 w-3.5 shrink-0 text-[#25D366]" />
    <span class="whitespace-nowrap text-[11px] font-medium text-ink">Recordatorio enviado</span>
    <span
      id="hcc-wa-check"
      class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-success text-white"
      style="transform: scale(0); transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1)"
    >
      <Check class="h-2.5 w-2.5" />
    </span>
  </div>

  <!-- Agenda — esquina inferior izquierda, flota hacia abajo -->
  <div
    id="hcc-signal-agenda"
    class="hcc-signal pointer-events-none absolute bottom-6 left-1 z-20 md:-left-3 md:bottom-10
           hidden md:flex items-center gap-2 rounded-full border border-line bg-white/95 px-3 py-2 backdrop-blur-sm"
  >
    <CalendarCheck2 class="h-3.5 w-3.5 shrink-0 text-brand" />
    <span class="whitespace-nowrap text-[11px] font-medium text-ink">Nueva cita agendada</span>
    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-brand text-white">
      <Check class="h-2.5 w-2.5" />
    </span>
  </div>

</div>

<style>
  /* ══════════════ Iluminación ambiental (CSS, fuera del WebP) ══════════════ */
  .hero-glow {
    position: absolute;
    display: block;
    border-radius: 50%;
    filter: blur(8px);
  }

  /* Glow principal — verde marca, amplio y elegante, domina la escena. */
  .hero-glow--primary {
    inset: -16% -12% -8% -12%;
    background: radial-gradient(54% 50% at 50% 46%,
      hsl(160 35% 28% / 0.34) 0%, hsl(160 35% 30% / 0.15) 44%, transparent 72%);
    filter: blur(32px);
  }

  /* Secundario cálido (terracota) — muy sutil, aporta profundidad. */
  .hero-glow--accent {
    inset: 12% -14% 22% 44%;
    background: radial-gradient(50% 50% at 62% 50%, hsl(16 75% 60% / 0.10) 0%, transparent 68%);
    filter: blur(32px);
  }

  /* Secundario verde claro — rebote inferior, integra con el fondo del hero. */
  .hero-glow--soft {
    inset: 40% 22% -12% 18%;
    background: radial-gradient(55% 55% at 45% 70%, hsl(158 40% 55% / 0.16) 0%, transparent 70%);
    filter: blur(28px);
  }

  /* Sombra de contacto anclada bajo la tablet (no flota → parallax con el mockup). */
  .hero-ground {
    inset: auto 12% -8% 12%;
    height: 24%;
    background: radial-gradient(50% 50% at 50% 50%, hsl(165 25% 12% / 0.22) 0%, transparent 72%);
    filter: blur(20px);
  }

  /* ══════════════ Tablet ══════════════ */
  .hero-tablet__float {
    position: relative;
    will-change: transform;
    animation: hero-tablet-float 7s ease-in-out infinite;
  }

  .hero-tablet {
    position: relative;
    width: 100%;
    aspect-ratio: 1536 / 1024;
  }

  /* Pantalla: recorte EXACTO del área visible del marco. */
  .hero-tablet__screen {
    position: absolute;
    top: 14.84%;
    left: 20.83%;
    width: 64.78%;
    height: 68.26%;
    overflow: hidden;
    border-radius: 0.7cqw; /* radio sutil, alineado al hueco de pantalla del marco */
    z-index: 0;
    /* Contenedor de consulta: permite escalar el panel fijo (1440px) por CSS puro. */
    container-type: size;
    background: hsl(40 33% 98%); /* respaldo por si el panel tarda un frame */
  }

  /* Escala proporcional del panel fijo (1440px de ancho) al ancho de la pantalla.
     100cqw / 1440px → factor sin unidades. Mantiene la relación de aspecto y la
     nitidez en Retina (el DOM se rasteriza al tamaño final). */
  .hero-tablet__scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 1440px;
    transform-origin: top left;
    transform: scale(calc(100cqw / 1440px));
  }

  /* Reflejo de cristal — sutil, diagonal, por encima del panel y bajo el marco. */
  .hero-tablet__screen::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      118deg,
      hsl(0 0% 100% / 0.14) 0%,
      hsl(0 0% 100% / 0.05) 12%,
      transparent 34%,
      transparent 100%
    );
  }

  /* Marco físico encima del panel; sombras físicas apiladas (silueta manos+tablet). */
  .hero-tablet__frame {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: block;
    width: 100%;
    height: 100%;
    filter:
      drop-shadow(0 7px 12px hsl(165 25% 12% / 0.12))
      drop-shadow(0 20px 36px hsl(160 30% 18% / 0.18))
      drop-shadow(0 46px 84px hsl(160 32% 14% / 0.20));
  }

  @keyframes hero-tablet-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-7px); }
  }

  /* ══════════════ Tarjetas flotantes ══════════════ */
  .hcc-signal {
    opacity: 0;
    transform: scale(0.85) translateY(6px);
    transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow:
      0 4px 10px hsl(165 25% 12% / 0.08),
      0 12px 28px hsl(160 30% 18% / 0.12);
  }
  .hcc-signal.hcc-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  #hcc-signal-wa.hcc-visible {
    animation: hcc-float-wa 2.4s ease-in-out 0.5s infinite;
  }
  #hcc-signal-agenda.hcc-visible {
    animation: hcc-float-agenda 3.2s ease-in-out 1.9s infinite;
  }

  @keyframes hcc-float-wa {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }
  @keyframes hcc-float-agenda {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(10px); }
  }

  /* ══════════════ Responsive: bajar intensidad, mantener composición ══════════════ */
  @media (max-width: 1023px) {
    .hero-glow--primary { filter: blur(20px); background: radial-gradient(52% 48% at 50% 46%, hsl(160 35% 28% / 0.20) 0%, transparent 72%); }
    .hero-glow--accent  { opacity: 0.7; }
    .hero-glow--soft    { opacity: 0.7; }
    .hero-ground        { opacity: 0.7; }
    .hero-tablet__frame {
      filter:
        drop-shadow(0 5px 10px hsl(165 25% 12% / 0.10))
        drop-shadow(0 16px 34px hsl(160 30% 18% / 0.14));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-tablet__float { animation: none; }
    .hcc-signal   { opacity: 1; transform: none; transition: none; }
    #hcc-signal-wa.hcc-visible,
    #hcc-signal-agenda.hcc-visible { animation: none; }
  }
</style>

<script>
(function () {
  var pref = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var waEl    = document.getElementById('hcc-signal-wa');
  var agEl    = document.getElementById('hcc-signal-agenda');
  var waCheck = document.getElementById('hcc-wa-check');

  function activate() {
    setTimeout(function () { if (waEl) waEl.classList.add('hcc-visible'); }, pref ? 0 : 500);
    setTimeout(function () { if (agEl) agEl.classList.add('hcc-visible'); }, pref ? 0 : 800);
    setTimeout(function () { if (waCheck) waCheck.style.transform = 'scale(1)'; }, pref ? 0 : 1100);
  }

  if (pref) { activate(); return; }

  var anchor = document.getElementById('hero-control');
  if (!anchor) return;

  var obs = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting) {
      obs.disconnect();
      activate();
    }
  }, { threshold: 0.2 });
  obs.observe(anchor);
})();
</script>
