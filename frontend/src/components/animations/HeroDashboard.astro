---
import PawPrint from '../icons/PawPrint.astro';
import Stethoscope from '../icons/Stethoscope.astro';
import Check from '../icons/Check.astro';
import ShieldCheck from '../icons/ShieldCheck.astro';
import WhatsApp from '../icons/WhatsApp.astro';

const citas = [
  { hora: "10:30", nombre: "Toby", tipo: "Vacunación" },
  { hora: "12:00", nombre: "Rocky", tipo: "Consulta" },
  { hora: "14:30", nombre: "Mía", tipo: "Control" },
];
---

<div id="hero-control" class="relative mx-auto w-full max-w-[460px]">

  <!-- Ambient glow -->
  <div class="pointer-events-none absolute -inset-8 -z-10 rounded-[3rem] bg-brand/8 blur-3xl opacity-60" />

  <!-- ── Main panel ── -->
  <div class="relative z-10 overflow-hidden rounded-2xl border border-line bg-white shadow-lift">

    <!-- Header -->
    <div class="flex items-center justify-between border-b border-line bg-muted/25 px-5 py-3">
      <p class="text-[10px] font-semibold uppercase tracking-widest text-ink-tertiary">Hoy en tu clínica</p>
      <div class="flex items-center gap-1.5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-success opacity-60 hcc-ping" />
          <span class="relative inline-flex h-2 w-2 rounded-full bg-success" />
        </span>
        <span class="text-[11px] text-ink-secondary">En línea</span>
      </div>
    </div>

    <!-- Active patient -->
    <div class="border-b border-line/40 px-5 py-4">
      <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-ink-tertiary">Paciente activo</p>
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand/10 text-brand">
          <PawPrint class="h-5 w-5" />
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-ink leading-tight">Luna · Golden Retriever</p>
          <div class="mt-0.5 flex items-center gap-1 text-xs text-ink-secondary">
            <Stethoscope class="h-3 w-3 shrink-0" />
            <span>Consulta general · Dr. García</span>
          </div>
        </div>
        <span class="shrink-0 rounded-full bg-success/10 px-2.5 py-1 text-[10px] font-semibold tracking-wide text-success">
          En curso
        </span>
      </div>
    </div>

    <!-- Upcoming appointments -->
    <div class="border-b border-line/40 px-5 py-4">
      <p class="mb-2.5 text-[10px] font-semibold uppercase tracking-widest text-ink-tertiary">Próximas citas</p>
      <div class="space-y-0.5">
        {citas.map((c, i) => (
          <div
            class="hcc-appt-row flex items-center gap-3 rounded-lg px-2 py-2.5"
            style={`animation-delay: ${0.85 + i * 0.12}s`}
          >
            <span class="w-10 shrink-0 font-mono text-xs text-ink-tertiary">{c.hora}</span>
            <div class="h-4 w-0.5 shrink-0 rounded-full bg-brand/30" />
            <p class="flex-1 text-sm font-medium text-ink">{c.nombre}</p>
            <span class="text-xs text-ink-secondary">{c.tipo}</span>
            <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-brand/40" />
          </div>
        ))}
      </div>
    </div>

    <!-- Income + progress -->
    <div class="px-5 py-4">
      <div class="flex items-baseline justify-between">
        <p class="text-sm text-ink-secondary">Ingresos del día</p>
        <p class="font-display text-xl font-semibold text-ink" id="hcc-income">$0</p>
      </div>
      <div class="mt-2.5 h-1.5 overflow-hidden rounded-full bg-line/60">
        <div id="hcc-progress" class="h-full w-0 rounded-full bg-brand" style="transition: width 1.1s cubic-bezier(0.16,1,0.3,1)" />
      </div>
      <p class="mt-1.5 text-[11px] text-ink-tertiary">4 de 6 citas completadas hoy</p>
    </div>

  </div>

  <!--
    Signals anchored at panel corners, floating AWAY from the panel.
    WA: top-right corner → floats up-right
    Sync: bottom-left corner → floats down-left
    Both stay within the hero section bounds.
  -->

  <!-- WA — top-right corner, floats up -->
  <div
    id="hcc-signal-wa"
    class="hcc-signal pointer-events-none absolute -top-5 right-4 z-20
           hidden md:flex items-center gap-2 rounded-full border border-line bg-white px-3 py-2 shadow-soft"
  >
    <WhatsApp class="h-3.5 w-3.5 shrink-0 text-[#25D366]" />
    <span class="whitespace-nowrap text-[11px] font-medium text-ink">Recordatorio enviado</span>
    <span
      id="hcc-wa-check"
      class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-success text-white"
      style="transform: scale(0); transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1)"
    >
      <Check class="h-2.5 w-2.5" />
    </span>
  </div>

  <!-- Sync — bottom-left corner, floats down -->
  <div
    id="hcc-signal-sync"
    class="hcc-signal pointer-events-none absolute -bottom-5 left-4 z-20
           hidden md:flex items-center gap-2 rounded-full border border-line bg-white px-3 py-2 shadow-soft"
  >
    <ShieldCheck class="h-3.5 w-3.5 shrink-0 text-brand" />
    <span class="whitespace-nowrap text-[11px] font-medium text-ink">Historial actualizado</span>
    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-brand text-white">
      <Check class="h-2.5 w-2.5" />
    </span>
  </div>

</div>

<style>
  /* ── Row entrance ── */
  .hcc-appt-row {
    opacity: 0;
    animation: hcc-row-enter 0.4s ease forwards;
  }
  @keyframes hcc-row-enter {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Signals: entrance pop ── */
  .hcc-signal {
    opacity: 0;
    transform: scale(0.85) translateY(6px);
    transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
  }
  .hcc-signal.hcc-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* ── Signals: opposite directions, different speeds, large delay gap ── */
  /* WA floats UP — 2.4s */
  #hcc-signal-wa.hcc-visible {
    animation: hcc-float-wa 2.4s ease-in-out 0.5s infinite;
  }
  /* Sync floats DOWN — 3.2s, starts 1.9s later so never in phase with WA */
  #hcc-signal-sync.hcc-visible {
    animation: hcc-float-sync 3.2s ease-in-out 1.9s infinite;
  }

  @keyframes hcc-float-wa {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-14px); }
  }

  @keyframes hcc-float-sync {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(12px); }
  }

  /* Pulse dot */
  .hcc-ping {
    animation: hcc-ping 2s cubic-bezier(0,0,0.2,1) infinite;
  }
  @keyframes hcc-ping {
    75%, 100% { transform: scale(2.2); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hcc-appt-row { opacity: 1; animation: none; }
    .hcc-signal   { opacity: 1; transform: none; transition: none; }
    #hcc-signal-wa.hcc-visible,
    #hcc-signal-sync.hcc-visible { animation: none; }
    .hcc-ping     { animation: none; }
  }
</style>

<script>
(function () {
  var pref = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var incomeEl   = document.getElementById('hcc-income');
  var progressEl = document.getElementById('hcc-progress');
  var waEl       = document.getElementById('hcc-signal-wa');
  var syncEl     = document.getElementById('hcc-signal-sync');
  var waCheck    = document.getElementById('hcc-wa-check');

  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  function countUp(el, target, duration) {
    if (!el) return;
    if (pref) { el.textContent = '$' + target.toLocaleString('en-US'); return; }
    var start = performance.now();
    function step(now) {
      var p = Math.min((now - start) / duration, 1);
      el.textContent = '$' + Math.round(easeOut(p) * target).toLocaleString('en-US');
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function activate() {
    countUp(incomeEl, 8450, 1400);

    setTimeout(function () {
      if (progressEl) progressEl.style.width = '66.7%';
    }, pref ? 0 : 150);

    setTimeout(function () {
      if (waEl) waEl.classList.add('hcc-visible');
    }, pref ? 0 : 900);

    setTimeout(function () {
      if (syncEl) syncEl.classList.add('hcc-visible');
    }, pref ? 0 : 1200);

    setTimeout(function () {
      if (waCheck) waCheck.style.transform = 'scale(1)';
    }, pref ? 0 : 1500);
  }

  if (pref) { activate(); return; }

  var panel = document.getElementById('hero-control');
  if (!panel) return;

  var obs = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting) {
      obs.disconnect();
      activate();
    }
  }, { threshold: 0.2 });
  obs.observe(panel);
})();
</script>
