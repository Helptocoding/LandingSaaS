---
import type { CollectionEntry } from 'astro:content';
import ArrowRight from '../icons/ArrowRight.astro';
import { getCategory, getAuthor, readingTime, formatDate, isoDate } from '../../data/blog';

export interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
  reveal?: string;
}
const { post, index = 0, reveal = 'fade-up' } = Astro.props;

const cat = getCategory(post.data.category);
const author = getAuthor(post.data.author);
const rt = readingTime(post.body ?? '', post.data.readingTimeOverride);
const href = `/blog/${post.id}/`;

// Índice de búsqueda del listado (filtrado cliente en /blog y en pilares).
const searchIndex = [
  post.data.title,
  post.data.description,
  cat?.name ?? '',
  ...(post.data.keywords ?? []),
]
  .join(' ')
  .toLowerCase();
---

<article
  data-post
  data-category={post.data.category}
  data-search={searchIndex}
  data-reveal={reveal}
  data-reveal-delay={String((index % 3) * 0.08)}
  class="group/card relative isolate flex flex-col bg-surface p-6 lg:p-8"
>
  <span
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 ease-out group-hover/card:opacity-100"
    style="background:radial-gradient(120% 90% at 0% 0%, hsl(160 35% 40% / 0.08), transparent 62%)"
  ></span>

  <div class="relative flex-1">
    {cat && (
      <a
        href={`/blog/categoria/${cat.slug}/`}
        class="relative z-10 text-xs font-semibold uppercase tracking-[0.14em] text-brand transition-colors hover:text-brand-hover"
      >
        {cat.name}
      </a>
    )}
    <h3 class="mt-3 font-display text-lg font-semibold tracking-tight text-ink text-balance">
      <a href={href} class="after:absolute after:inset-0">{post.data.title}</a>
    </h3>
    <p class="mt-2.5 line-clamp-3 text-sm leading-relaxed text-ink-secondary">
      {post.data.description}
    </p>
  </div>

  <div class="relative mt-5 flex items-center justify-between text-xs text-ink-tertiary">
    <time datetime={isoDate(post.data.publishDate)}>{formatDate(post.data.publishDate)}</time>
    <span class="inline-flex items-center gap-1.5">
      {rt} min
      <ArrowRight class="h-3.5 w-3.5 transition-transform duration-300 group-hover/card:translate-x-0.5" />
    </span>
  </div>
</article>
