---
// Migas visibles. El schema BreadcrumbList se emite aparte (en BlogLayout /
// página de categoría) para centralizar los JSON-LD.
export interface Crumb {
  label: string;
  href?: string;
}
export interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Ruta de navegación" class="text-sm">
  <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-ink-tertiary">
    {
      items.map((c, i) => {
        const last = i === items.length - 1;
        return (
          <li class="flex items-center gap-x-1.5">
            {c.href && !last ? (
              <a href={c.href} class="transition-colors hover:text-ink">{c.label}</a>
            ) : (
              <span class="text-ink-secondary" aria-current={last ? 'page' : undefined}>{c.label}</span>
            )}
            {!last && <span aria-hidden="true" class="text-line">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>
