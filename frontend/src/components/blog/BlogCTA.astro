---
// CTA de conversión hacia SaaslyVet. Reusa data-cta-kind → RegisterModal/DemoModal
// (delegación global ya montada en Base). No necesita JS propio.
import ArrowRight from '../icons/ArrowRight.astro';

export interface Props {
  kind?: 'trial' | 'demo' | 'sales';
  title?: string;
  text?: string;
  label?: string;
}
const {
  kind = 'trial',
  title = '¿Listo para ordenar tu clínica?',
  text = 'SaaslyVet centraliza agenda, expediente clínico, inventario y cobros en un solo lugar, con recordatorios automáticos por WhatsApp. Pruébalo gratis, sin tarjeta.',
  label = 'Empieza gratis',
} = Astro.props;
---

<aside
  data-reveal="fade-up"
  class="relative overflow-hidden rounded-2xl bg-gradient-primary p-8 text-surface lg:p-10"
>
  <div
    class="absolute inset-0 opacity-[0.18]"
    aria-hidden="true"
    style="background-image: radial-gradient(circle at 15% 20%, hsl(158 40% 55%) 0%, transparent 40%), radial-gradient(circle at 90% 90%, hsl(16 75% 60%) 0%, transparent 40%)"
  >
  </div>
  <div class="relative max-w-xl">
    <h2 class="font-display text-2xl font-semibold tracking-tight text-white text-balance lg:text-3xl">
      {title}
    </h2>
    <p class="mt-3 leading-relaxed text-white/75">{text}</p>
    <button
      type="button"
      data-cta-kind={kind}
      class="mt-6 inline-flex items-center gap-2 rounded-md bg-surface px-5 py-3 font-medium text-ink transition-colors hover:bg-white"
    >
      {label}
      <ArrowRight class="h-4 w-4" />
    </button>
  </div>
</aside>
