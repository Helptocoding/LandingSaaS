---
import Logo from '../ui/Logo.astro';

// Producto = anclas a secciones del home (absolutas con "/#" para que también
// funcionen desde las páginas legales). Demo = botón que abre DemoModal vía
// data-cta-kind (delegación global en DemoModal.astro). Empresa/Legal = rutas reales.
const productLinks = [
  { label: "Funciones", href: "/#features" },
  { label: "Automatización WhatsApp", href: "/#automation" },
  { label: "Precios", href: "/#pricing" },
];

const companyLinks = [
  { label: "Blog", href: "/blog/" },
  { label: "Sobre nosotros", href: "/nosotros" },
  { label: "Contacto", href: "/contacto" },
];

const legalLinks = [
  { label: "Aviso de privacidad", href: "/aviso-de-privacidad" },
  { label: "Términos y condiciones", href: "/terminos" },
  { label: "Cookies", href: "/cookies" },
];
---

<footer class="border-t border-line bg-muted/20">
  <div class="container-wide py-16">
    <div class="grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <Logo />
        <p class="mt-4 text-sm text-ink-secondary max-w-xs leading-relaxed">
          Software de gestión veterinaria para clínicas pequeñas y medianas. Agenda, expedientes, inventario y cobros en un solo lugar.
        </p>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8">
        <div>
          <p class="font-display text-sm font-semibold text-ink mb-4">Producto</p>
          <ul class="space-y-2.5">
            {productLinks.map((l) => (
              <li><a href={l.href} class="text-sm text-ink-secondary hover:text-ink transition-colors">{l.label}</a></li>
            ))}
            <li>
              <button
                data-cta-kind="demo"
                class="text-sm text-ink-secondary hover:text-ink transition-colors"
              >
                Demo
              </button>
            </li>
          </ul>
        </div>

        <div>
          <p class="font-display text-sm font-semibold text-ink mb-4">Empresa</p>
          <ul class="space-y-2.5">
            {companyLinks.map((l) => (
              <li><a href={l.href} class="text-sm text-ink-secondary hover:text-ink transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <p class="font-display text-sm font-semibold text-ink mb-4">Legal</p>
          <ul class="space-y-2.5">
            {legalLinks.map((l) => (
              <li><a href={l.href} class="text-sm text-ink-secondary hover:text-ink transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-line flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-ink-secondary">2026 SaaslyVet </p>
      <p class="text-xs text-ink-secondary">Hecho en México para ayudar a clínicas veterinarias a trabajar de forma más organizada.</p>
    </div>
  </div>
</footer>
