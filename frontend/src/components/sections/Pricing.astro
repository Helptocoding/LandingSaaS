---
import Check from '../icons/Check.astro';
import Sparkles from '../icons/Sparkles.astro';

const tiers = [
  {
    name: "Inicio",
    desc: "Todo lo necesario para digitalizar tu clínica desde el primer día.",
    monthly: 399, monthly_orig: 599,
    yearly: 329, yearly_orig: 499,
    features: ["Hasta 2 veterinarios", "Agenda y expediente clínico", "Inventario básico", "Soporte por email"],
    cta: "Empezar gratis", kind: "trial",
  },
  {
    name: "Profesional",
    desc: "Para operar tu clínica completa con automatizaciones.",
    monthly: 799, monthly_orig: 1199,
    yearly: 649, yearly_orig: 999,
    features: ["Veterinarios ilimitados", "Todo en Inicio", "WhatsApp automatizado", "POS y cierre de caja", "Reportes avanzados", "Soporte prioritario"],
    cta: "Probar 14 días", popular: true, kind: "trial",
  },
  {
    name: "Clínica Plus",
    desc: "Para automatizar y crecer.",
    monthly: 1599, monthly_orig: 2499,
    yearly: 1299, yearly_orig: 1999,
    features: ["Multi-sucursal", "Roles y auditoría avanzada", "API e integraciones", "Gestor de cuenta dedicado", "Onboarding personalizado"],
    cta: "Hablar con ventas", kind: "sales",
  },
  {
    name: "Empresarial",
    desc: "Para grupos veterinarios y cadenas multisucursal.",
    enterprise: true,
    features: ["Sucursales ilimitadas", "Usuarios ilimitados", "API e integraciones avanzadas", "SLA dedicado", "Onboarding personalizado", "Gestor de cuenta asignado"],
    cta: "Contactar ventas", kind: "sales",
  },
];
---

<section id="pricing" class="py-12 lg:py-24">
  <div class="container-wide">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-sm font-medium text-brand mb-3">Precios</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance">
        Planes simples. Sin cargos por paciente.
      </h2>
      <p class="mt-5 text-lg text-ink-secondary">
        Comienza gratis 14 días. Cancela cuando quieras.
      </p>

      <!-- Segmented toggle -->
      <div class="mt-8 inline-flex items-center rounded-xl border border-line bg-muted/50 p-1">
        <button
          id="btn-yearly"
          class="rounded-lg px-5 py-2 text-sm font-medium transition-all bg-white shadow-soft text-ink"
        >
          Anual
          <span id="yearly-badge" class="ml-1.5 text-[10px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded-md bg-brand/10 text-brand">−17%</span>
        </button>
        <button
          id="btn-monthly"
          class="rounded-lg px-5 py-2 text-sm font-medium transition-all text-ink-secondary"
        >
          Mensual
        </button>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5" id="pricing-cards">
      {tiers.map((t, i) => (
        <div
          data-reveal="fade-up"
          data-reveal-delay={String(i * 0.1)}
          class={`relative flex flex-col rounded-3xl border p-7 ${
            t.popular
              ? "border-2 border-brand bg-gradient-to-b from-white to-brand-soft/30 shadow-lift"
              : "border-line bg-white"
          }`}
        >
          {t.popular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 inline-flex items-center gap-1 rounded-full bg-brand text-white px-3 py-1 text-[10px] uppercase tracking-wider font-semibold shadow-sm">
              <Sparkles class="h-3 w-3" /> Más elegido
            </div>
          )}

          <h3 class="font-display text-xl font-semibold text-ink">{t.name}</h3>
          <p class="mt-1 text-sm text-ink-secondary">{t.desc}</p>

          {t.enterprise ? (
            <div class="mt-6">
              <p class="font-display text-4xl font-semibold text-ink">Hablemos</p>
              <p class="mt-1 text-xs text-ink-secondary">Cotización personalizada</p>
            </div>
          ) : (
            <div class="mt-6">
              <div class="flex items-baseline gap-2">
                <span class="font-display text-4xl font-semibold text-ink" data-price-yearly={t.yearly} data-price-monthly={t.monthly}>
                  ${t.yearly?.toLocaleString('es-MX')}
                </span>
                <span class="text-sm text-ink-secondary">/ mes</span>
              </div>
              <div class="mt-1 flex items-center gap-2">
                <span class="text-xs line-through text-ink-tertiary" data-orig-yearly={t.yearly_orig} data-orig-monthly={t.monthly_orig}>
                  ${t.yearly_orig?.toLocaleString('es-MX')}
                </span>
                <span class="text-[10px] text-ink-tertiary" data-billing-text>facturación anual</span>
              </div>
            </div>
          )}

          <ul class="mt-6 space-y-3">
            {t.features.map((f) => (
              <li class="flex gap-2.5 text-sm text-ink">
                <Check class="h-4 w-4 text-brand mt-0.5 shrink-0" />
                {f}
              </li>
            ))}
          </ul>

          <button
            data-cta-kind={t.kind}
            class={`mt-auto mt-8 h-11 w-full rounded-md text-sm font-medium transition-colors ${
              t.popular
                ? "bg-brand text-white hover:bg-brand-hover"
                : t.enterprise
                ? "bg-ink text-surface hover:bg-ink/90"
                : "bg-white text-ink border border-line hover:bg-muted"
            }`}
          >
            {t.cta}
          </button>
        </div>
      ))}
    </div>

    <p class="text-center text-xs text-ink-secondary mt-8">
      Todos los precios en MXN. Incluye actualizaciones, soporte en español y backups diarios.
    </p>
  </div>
</section>

<script>
  var btnYearly  = document.getElementById('btn-yearly');
  var btnMonthly = document.getElementById('btn-monthly');
  var yearlyBadge = document.getElementById('yearly-badge');
  var yearly = true;

  function setActive(btn, other) {
    btn.classList.add('bg-white', 'shadow-soft', 'text-ink');
    btn.classList.remove('text-ink-secondary');
    other.classList.remove('bg-white', 'shadow-soft', 'text-ink');
    other.classList.add('text-ink-secondary');
  }

  function updatePrices() {
    document.querySelectorAll('[data-price-yearly]').forEach(function (el) {
      var val = yearly
        ? parseInt(el.getAttribute('data-price-yearly'))
        : parseInt(el.getAttribute('data-price-monthly'));
      el.textContent = '$' + val.toLocaleString('es-MX');
    });
    document.querySelectorAll('[data-orig-yearly]').forEach(function (el) {
      var val = yearly
        ? parseInt(el.getAttribute('data-orig-yearly'))
        : parseInt(el.getAttribute('data-orig-monthly'));
      el.textContent = '$' + val.toLocaleString('es-MX');
    });
    document.querySelectorAll('[data-billing-text]').forEach(function (el) {
      el.textContent = yearly ? 'facturación anual' : 'facturación mensual';
    });
    if (yearlyBadge) yearlyBadge.style.display = yearly ? '' : 'none';
  }

  if (btnYearly) btnYearly.addEventListener('click', function () {
    yearly = true;
    setActive(btnYearly, btnMonthly);
    updatePrices();
  });
  if (btnMonthly) btnMonthly.addEventListener('click', function () {
    yearly = false;
    setActive(btnMonthly, btnYearly);
    updatePrices();
  });
</script>

<script type="module">
  import { ctaToast } from '../../lib/cta.js';
  document.querySelectorAll('[data-cta-kind]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      ctaToast(this.getAttribute('data-cta-kind'));
    });
  });
</script>
