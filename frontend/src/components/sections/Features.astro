---
import Stethoscope from '../icons/Stethoscope.astro';
import CalendarDays from '../icons/CalendarDays.astro';
import Package from '../icons/Package.astro';
import CreditCard from '../icons/CreditCard.astro';
import MessageCircle from '../icons/MessageCircle.astro';
import BarChart3 from '../icons/BarChart3.astro';
import FileText from '../icons/FileText.astro';
import Users from '../icons/Users.astro';

// Bento asimétrico (composición C). Spans SOLO en lg: (col-start/row-start explícitos).
// Sin tintes de fondo: la vida = hover (gradiente + línea de acento) + entrada escalonada.
// side = mitad del bento (lg). left entra desde la izquierda, right desde la derecha.
const cells = [
  { icon: CalendarDays, title: "Agenda con recordatorios", desc: "Citas online y recordatorios automáticos por WhatsApp. Tus clientes confirman solos y las ausencias caen.", tone: "brand", size: "wide", side: "left", area: "lg:col-start-1 lg:row-start-1 lg:col-span-2" },
  { icon: Stethoscope, title: "Expediente clínico digital", desc: "Consultas, recetas, vacunas y archivos. Toda la historia de cada paciente en una pantalla.", tone: "accent", size: "tall", side: "right", area: "lg:col-start-3 lg:row-start-1 lg:row-span-2" },
  { icon: Package, title: "Inventario automático", desc: "Se descuenta con cada tratamiento. Alertas de stock y caducidad.", tone: "brand", size: "sm", side: "right", area: "lg:col-start-4 lg:row-start-1" },
  { icon: CreditCard, title: "Cobros y cierre de caja", desc: "Cobro rápido, varios métodos de pago y cierre sin recapturar.", tone: "accent", size: "sm", side: "left", area: "lg:col-start-1 lg:row-start-2" },
  { icon: BarChart3, title: "Reportes en tiempo real", desc: "Ingresos, productos más vendidos, ocupación y retención.", tone: "brand", size: "sm", side: "left", area: "lg:col-start-2 lg:row-start-2" },
  { icon: FileText, title: "Recetas en un clic", desc: "Generación y firma digital, listas para imprimir o enviar.", tone: "accent", size: "sm", side: "right", area: "lg:col-start-4 lg:row-start-2" },
  { icon: MessageCircle, title: "Recordatorios por WhatsApp", desc: "Citas, vacunas y seguimientos automáticos. Sin levantar el teléfono.", tone: "brand", size: "wide", side: "left", area: "lg:col-start-1 lg:row-start-3 lg:col-span-2" },
  { icon: Users, title: "Permisos por rol", desc: "Accesos por veterinario, recepción y administración. Sin accidentes, sin confusión.", tone: "accent", size: "wide", side: "right", area: "lg:col-start-3 lg:row-start-3 lg:col-span-2" },
];
---

<section id="features" class="py-14 lg:py-24">
  <div class="container-wide">
    <div class="mx-auto max-w-2xl text-center mb-10 lg:mb-16">
      <p class="text-sm font-medium text-brand mb-3">Funciones</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance">
        Una plataforma diseñada para cómo funciona una veterinaria.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ink-secondary leading-relaxed">
        Conecta agenda, atención, inventario y administración. Cada acción alimenta al sistema completo.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl bg-line ring-1 ring-line sm:grid-cols-2 lg:grid-cols-4 lg:grid-rows-3">
      {cells.map((c, i) => {
        const big = c.size === "wide" || c.size === "tall";
        const grad = c.tone === "accent"
          ? "radial-gradient(120% 90% at 0% 0%, hsl(16 75% 60% / 0.10), transparent 62%)"
          : "radial-gradient(120% 90% at 0% 0%, hsl(160 35% 40% / 0.10), transparent 62%)";
        return (
          <div
            data-reveal={c.side === "left" ? "slide-right" : "slide-left"}
            data-reveal-delay={String(i * 0.09)}
            class={`group/cell relative isolate flex flex-col bg-surface ${big ? "p-6 lg:p-8" : "p-6 lg:p-7"} ${c.area}`}
          >
            <span aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 ease-out group-hover/cell:opacity-100" style={`background:${grad}`}></span>

            <c.icon class={`relative ${big ? "h-8 w-8" : "h-7 w-7"} ${c.tone === "accent" ? "text-accent" : "text-brand"} transition-transform duration-300 ease-out group-hover/cell:-translate-y-0.5 group-hover/cell:scale-105`} />

            <span class={`relative mt-5 block h-[3px] w-7 rounded-full ${c.tone === "accent" ? "bg-accent" : "bg-brand"} transition-all duration-300 ease-out group-hover/cell:w-14`}></span>

            <div class="relative mt-4">
              <h3 class="font-display text-base font-semibold text-ink tracking-tight text-balance">{c.title}</h3>
              <p class="mt-2 text-sm text-ink-secondary leading-relaxed">{c.desc}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Aparición más suave (solo Funciones): más larga + easing gentil */
  #features [data-reveal] {
    transition-duration: 1.1s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
