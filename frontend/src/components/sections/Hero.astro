---
import ArrowRight from '../icons/ArrowRight.astro';
import Check from '../icons/Check.astro';
import HeroDashboard from '../animations/HeroDashboard.astro';
---

<section id="hero" class="relative pt-20 lg:pt-32 pb-12 lg:pb-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-hero -z-10" />
  <div class="absolute inset-0 -z-10" style="opacity: 0.18; background-image: linear-gradient(hsl(160 35% 28% / 0.08) 1px, transparent 1px), linear-gradient(90deg, hsl(160 35% 28% / 0.08) 1px, transparent 1px); background-size: 42px 42px; mask-image: radial-gradient(60% 60% at 50% 35%, black 40%, transparent 100%)" id="hero-grid" />
  <div id="hero-blob-left" class="absolute -top-20 -left-20 h-72 w-72 rounded-full bg-brand/10 blur-3xl -z-10" />
  <div id="hero-blob-right" class="absolute top-32 right-0 h-80 w-80 rounded-full bg-accent/15 blur-3xl -z-10" />

  <div class="container-wide relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-start lg:items-center">
      <!-- Left column -->
      <div class="lg:col-span-6">
        <!-- Beta badge — social proof -->
        <!-- Positioning -->
        <p class="hero-entrance text-[11px] font-semibold uppercase tracking-[0.20em] text-ink-secondary mb-4" style="animation-delay: 0.03s">SOFTWARE DE GESTIÓN VETERINARIA</p>

        <!-- Heading -->
        <h1 class="hero-entrance mt-6 font-display text-4xl sm:text-5xl lg:text-6xl font-semibold leading-[1.05] tracking-tight text-ink text-balance" style="animation-delay: 0.05s">
          Gestiona tu clínica veterinaria
          <span class="block">
            sin libretas, sin Excel,
            <span class="relative inline-block">
              <span class="relative z-10 text-brand">sin caos.</span>
              <svg viewBox="0 0 200 12" class="absolute -bottom-1 left-0 w-full h-2 text-accent" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M2 8 C 55 2, 145 2, 198 8" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
              </svg>
            </span>
          </span>
        </h1>

        <!-- Description -->
        <p class="hero-entrance mt-6 max-w-xl text-base sm:text-lg text-ink-secondary leading-relaxed" style="animation-delay: 0.12s">
          Centraliza agenda, expedientes clínicos, inventario y cobros en una sola plataforma. Lista para usar desde el primer día. Sin instalaciones, sin capacitación técnica.
        </p>

        <!-- Identification -->
        <p class="hero-entrance mt-3 max-w-lg text-sm text-ink-tertiary leading-relaxed" style="animation-delay: 0.14s">
          Para veterinarios y clínicas pequeñas que gestionan su día entre consultas, WhatsApp y administración.
        </p>

        <!-- CTAs -->
        <div class="hero-entrance mt-8 flex flex-col sm:flex-row gap-3" style="animation-delay: 0.18s">
          <button
            data-testid="hero-trial-btn"
            data-cta-kind="trial"
            class="inline-flex items-center gap-2 bg-ink text-surface rounded-md px-6 py-3.5 font-medium hover:bg-ink/90 transition-colors shadow-soft group h-12"
          >
            Registrate gratis
            <ArrowRight class="ml-2 h-4 w-4" />
          </button>
          <button
            data-testid="hero-demo-btn"
            data-cta-kind="demo"
            class="inline-flex items-center gap-2 bg-white text-ink border border-line rounded-md px-6 py-3.5 font-medium hover:bg-muted transition-colors h-12"
          >
            Probar demo en 2 min →
          </button>
        </div>
        
      </div>

      <!-- Right column: Control center -->
      <div class="hero-entrance lg:col-span-6 relative will-change-transform lg:-mt-14" id="hero-dash-wrapper" style="animation-delay: 0.2s">
        <HeroDashboard />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-entrance {
    opacity: 0;
    animation: hero-fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-entrance {
      opacity: 1;
      animation: none;
    }
  }
</style>

<script type="module">
  import { ctaToast } from '../../lib/cta.js';
  document.querySelectorAll('#hero [data-cta-kind]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      ctaToast(this.getAttribute('data-cta-kind'));
    });
  });
</script>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Parallax solo en desktop (≥768px): en móvil casi no se percibe y ahorra trabajo de scroll/main-thread (INP).
  const isDesktop = window.matchMedia('(min-width: 768px)').matches;
  if (!prefersReduced && isDesktop) {
    const section = document.getElementById('hero');
    const dashWrapper = document.getElementById('hero-dash-wrapper');
    const grid = document.getElementById('hero-grid');
    const blobL = document.getElementById('hero-blob-left');
    const blobR = document.getElementById('hero-blob-right');
    let ticking = false;

    function updateParallax() {
      const rect = section.getBoundingClientRect();
      const total = section.offsetHeight;
      const scrolled = -rect.top;
      const pct = total > 0 ? Math.max(0, Math.min(1, scrolled / total)) : 0;

      if (dashWrapper) {
        // Parallax limpio (sin rotación) — compone con la flotación del mockup en el elemento interno.
        dashWrapper.style.transform = 'translateY(' + (pct * -70) + 'px) scale(' + (1 - pct * 0.04) + ')';
      }
      if (blobL) {
        blobL.style.transform = 'translateY(' + (pct * 120) + 'px)';
      }
      if (blobR) {
        blobR.style.transform = 'translateY(' + (pct * 120) + 'px)';
      }
      if (grid) {
        grid.style.opacity = pct > 0.8 ? 0 : 0.18;
      }
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
