---
import Calendar from '../icons/Calendar.astro';
import Stethoscope from '../icons/Stethoscope.astro';
import Syringe from '../icons/Syringe.astro';
import CreditCard from '../icons/CreditCard.astro';
import MessageCircle from '../icons/MessageCircle.astro';

const timeline = [
  { time: "08:30 — Recepción", desc: "Luna llega a vacunación. El equipo encuentra su expediente en segundos.", icon: Calendar },
  { time: "09:15 — Consulta", desc: "El veterinario revisa historial, vacunas y tratamientos anteriores en una sola pantalla.", icon: Stethoscope },
  { time: "09:45 — Tratamiento", desc: "Los productos utilizados quedan registrados y el inventario se actualiza automáticamente.", icon: Syringe },
  { time: "10:00 — Cobro", desc: "La recepción cobra la consulta sin volver a capturar información. El ticket ya tiene todo.", icon: CreditCard },
  { time: "Después", desc: "SaaslyVet mantiene el seguimiento con recordatorios por WhatsApp.", icon: MessageCircle },
];
---

<section class="py-20 lg:py-24">
  <div class="container-wide">
    <div class="rounded-[2rem] bg-gradient-primary relative overflow-hidden p-10 lg:p-16">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 80% 20%, hsl(158 40% 55%) 0%, transparent 50%), radial-gradient(circle at 10% 90%, hsl(16 75% 60%) 0%, transparent 50%)" />

      <div class="relative max-w-3xl mx-auto">
        <p class="text-sm font-medium text-white/80 mb-3 text-center">Un día usando SaaslyVet</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-white text-balance text-center">
          Así se siente tener todo conectado.
        </h2>

        <div class="mt-14 space-y-0">
          {timeline.map((step, i) => (
            <div data-reveal="fade-up" data-reveal-delay={String(i * 0.08)} class="relative flex gap-5 pb-10 last:pb-0">
              <div class="hidden sm:flex flex-col items-center">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15 text-white">
                  <step.icon class="h-5 w-5" />
                </div>
                {i < timeline.length - 1 && (
                  <div class="w-px flex-1 bg-white/15 mt-2" />
                )}
              </div>
              <div class="flex-1 pt-1">
                <p class="text-sm font-semibold text-white/90 mb-1">{step.time}</p>
                <p class="text-base text-white/70 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
