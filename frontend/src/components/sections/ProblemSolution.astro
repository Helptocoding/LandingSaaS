---
import Clock from '../icons/Clock.astro';
import Bell from '../icons/Bell.astro';
import CreditCard from '../icons/CreditCard.astro';
import Stethoscope from '../icons/Stethoscope.astro';

// Ruido operativo — solo frases de miedo concreto (dinero / clientes / clínico / control).
// Cada fila mezcla ejes y arranca con un "killer". Sin relleno neutro.
const rows = [
  ['¿Ya cobraron esta consulta?', '¿Dónde quedó el expediente?', 'Ese cliente nunca volvió', 'Un día más apagando incendios', 'Se acabó el medicamento', '¿Le tocaba refuerzo o no?', 'Otra llamada perdida'],
  ['La caja no cuadra', 'No encuentro la receta anterior', 'Se fue con la competencia', 'Dos pacientes a la misma hora', 'Ese lote ya venció', '¿Cuándo fue su última vacuna?'],
  ['Se fue sin pagar el medicamento', '¿Este paciente es alérgico a algo?', '¿Ya le recordaron su cita?', 'Tres urgencias al mismo tiempo', 'El mes cerró más bajo otra vez', 'Otra vez me quedé tarde capturando'],
];
// dir: alterna → ← →
const rowConf = [
  { dir: 'right', dur: '46s' },
  { dir: 'left', dur: '58s' },
  { dir: 'right', dur: '50s' },
];

const benefits = [
  { icon: Clock, title: 'Recuperas horas cada semana', desc: 'Menos captura manual y menos búsquedas. Ese tiempo vuelve a los pacientes.', tone: 'text-brand' },
  { icon: Bell, title: 'Nada se te escapa', desc: 'Citas, vacunas y seguimientos en piloto automático. Dejas de perder clientes por olvidos.', tone: 'text-accent' },
  { icon: CreditCard, title: 'Cobras todo y la caja cuadra', desc: 'Cada consulta y producto queda registrado. Cierras caja sin fugas ni sorpresas a fin de mes.', tone: 'text-brand' },
  { icon: Stethoscope, title: 'Toda la historia del paciente, a la mano', desc: 'Expediente, recetas y vacunas en una pantalla. Decides sin buscar entre papeles.', tone: 'text-accent' },
];
---

<section class="py-14 lg:py-20">
  <div class="container-wide">
    <!-- 1 · Encabezado -->
    <div data-reveal="fade-up" class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-ink tracking-tight text-balance">
        Todo esto pasa cada día en una clínica sin sistema.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ink-secondary leading-relaxed">
        SaaslyVet silencia el ruido para que recuperes tiempo, ingresos y tranquilidad.
      </p>
    </div>

    <!-- 2 · Banda dinámica de ruido operativo (contenida) -->
    <div
      class="noise-band mx-auto mt-10 max-w-3xl space-y-2.5 overflow-hidden rounded-2xl bg-muted/40 py-5"
      style="-webkit-mask-image:linear-gradient(to right,transparent,#000 5%,#000 95%,transparent);mask-image:linear-gradient(to right,transparent,#000 5%,#000 95%,transparent)"
    >
      <p class="sr-only">
        El día a día de una clínica sin sistema: consultas sin cobrar, expedientes perdidos, medicamento agotado, clientes que no vuelven, urgencias encimadas.
      </p>
      <div aria-hidden="true" class="space-y-2.5">
        {rows.map((row, r) => (
          <div class="marquee" data-dir={rowConf[r].dir} style={`--dur:${rowConf[r].dur}`}>
            <div class="marquee-track">
              {[0, 1].map((dup) => (
                <div class="marquee-group" data-dup={dup === 1 ? '' : undefined}>
                  {row.map((phrase) => (
                    <span class="mr-3 inline-flex items-center whitespace-nowrap rounded-full bg-surface px-4 py-2 text-sm font-medium text-ink-secondary shadow-soft">
                      {phrase}
                    </span>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Divisor sutil -->
    <div class="mt-8 h-px bg-gradient-to-r from-transparent via-line to-transparent"></div>

    <!-- 3 · Beneficios (retícula editorial, sin cards) -->
    <div data-reveal="fade-up" class="mt-8 grid grid-cols-1 gap-px bg-line sm:grid-cols-2 lg:grid-cols-4">
      {benefits.map((b) => (
        <div class="bg-page px-6 py-6 lg:py-7">
          <b.icon class={`h-6 w-6 ${b.tone}`} />
          <h3 class="mt-4 font-display text-base font-semibold text-ink tracking-tight text-balance">{b.title}</h3>
          <p class="mt-2 text-sm text-ink-secondary leading-relaxed">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee { overflow: hidden; }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-x var(--dur, 50s) linear infinite;
  }
  /* dir=right → se mueven hacia la derecha (keyframe invertido) */
  .marquee[data-dir="right"] .marquee-track { animation-direction: reverse; }
  .marquee-group { display: flex; flex: 0 0 auto; }

  /* Hover / focus pause (WCAG 2.2.2, sin controles visibles) */
  .marquee:hover .marquee-track,
  .marquee:focus-within .marquee-track { animation-play-state: paused; }

  @keyframes marquee-x {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .noise-band { -webkit-mask-image: none !important; mask-image: none !important; overflow: visible; }
    .marquee { overflow: visible; }
    .marquee-track { animation: none; width: auto; flex-wrap: wrap; }
    .marquee-group { flex-wrap: wrap; }
    .marquee-group[data-dup] { display: none; }
  }
</style>
