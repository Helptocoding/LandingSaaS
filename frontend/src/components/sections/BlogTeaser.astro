---
// Módulo "Del blog" para la home: pasa link equity de la página de mayor autoridad
// hacia los artículos y reduce su profundidad de clic. Muestra los 3 más recientes.
import { getCollection } from 'astro:content';
import ArticleCard from '../blog/ArticleCard.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const latest = (
  await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

{
  latest.length > 0 && (
    <section id="blog" class="py-16 lg:py-24">
      <div class="container-wide">
        <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <p class="text-sm font-medium text-brand mb-3">Del blog</p>
            <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight text-ink text-balance">
              Guías para gestionar y hacer crecer tu clínica
            </h2>
          </div>
          <a
            href="/blog/"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-ink transition-colors hover:text-brand"
          >
            Ver todo el blog
            <ArrowRight class="h-4 w-4" />
          </a>
        </div>

        <div class="grid gap-px overflow-hidden rounded-2xl bg-line ring-1 ring-line sm:grid-cols-2 lg:grid-cols-3">
          {latest.map((p, i) => (
            <ArticleCard post={p} index={i} />
          ))}
        </div>
      </div>
    </section>
  )
}
