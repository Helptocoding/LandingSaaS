---
import JsonLD from '../seo/JsonLD.astro';

const faqs = [
  { q: "¿Mis datos están seguros?", a: "Tus datos viajan cifrados mediante HTTPS/TLS y se respaldan todos los días con copias de seguridad cifradas fuera del sitio. La información de cada clínica queda aislada de las demás, y tú eres siempre el dueño de tu información." },
  { q: "¿Puedo migrar mis pacientes y expedientes actuales?", a: "Sí. Puedes importar tus clientes y pacientes desde archivos Excel o CSV, asignando tus columnas a los campos de SaaslyVet. Te acompañamos durante el proceso." },
  { q: "¿Cuánto tarda la implementación en mi clínica?", a: "Está pensada para ser rápida: creas tu cuenta, importas tus pacientes desde Excel o CSV y empiezas a usar la agenda y el expediente el mismo día. Te guiamos en la configuración inicial." },
  { q: "¿Hay permanencia o contrato anual obligatorio?", a: "No. Pagas mensual o anual y puedes cancelar cuando quieras. Si eliges el plan anual obtienes un descuento sobre el precio mensual." },
  { q: "¿Cómo funcionan los recordatorios por WhatsApp?", a: "SaaslyVet usa el historial de cada paciente para enviar por WhatsApp recordatorios de citas, avisos de vacunas y seguimientos. Defines las plantillas y las reglas de envío, y los mensajes salen en el momento adecuado." },
  { q: "¿Funciona si tengo varias clínicas?", a: "SaaslyVet está pensado para operar una clínica por cuenta. Si manejas más de una, podemos ayudarte a configurar una cuenta para cada clínica; escríbenos y vemos juntos el mejor esquema para tu caso." },
];

// FAQPage schema construido desde las MISMAS preguntas visibles (sin inventar contenido para SEO).
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<section id="faq" class="py-12 lg:py-24 bg-muted/30">
  <div class="container-narrow">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-sm font-medium text-brand mb-3">Preguntas frecuentes</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance">
        Todo lo que necesitas saber antes de empezar.
      </h2>
    </div>

    <div class="space-y-3" id="faq-list">
      {faqs.map((f, i) => (
        <div class="rounded-2xl border border-line bg-surface overflow-hidden">
          <button
            class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left text-base font-semibold text-ink hover:bg-muted/30 transition-colors"
            data-index={i}
          >
            {f.q}
            <span class="faq-icon transition-transform duration-200 text-ink-tertiary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </button>
          <div class="faq-content hidden px-6 pb-5 text-base text-ink-secondary leading-relaxed">
            {f.a}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<JsonLD schema={faqSchema} />

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn, idx) => {
    const content = btn.nextElementSibling as HTMLElement;
    const icon = btn.querySelector('.faq-icon') as HTMLElement;
    if (idx < 3) {
      content.classList.remove('hidden');
      icon.style.transform = 'rotate(180deg)';
    }
    btn.addEventListener('click', () => {
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden');
      icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
    });
  });
</script>
