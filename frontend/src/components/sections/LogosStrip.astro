---
const clinics = [
  "Clínica San Bernardo", "VetCare Pets", "Hospital Animalia",
  "PetSalud", "AnimaVet", "Casa Animal", "Mascolife", "VidaPet",
];
---

<section class="py-12 border-y border-line bg-muted/30">
  <div class="container-wide">
    <p class="text-center text-xs uppercase tracking-[0.2em] text-ink-secondary mb-8">
      Confían en SaaslyVet más de 1.200 clínicas en América Latina y España
    </p>
    <div class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-page to-transparent z-10" />
      <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-page to-transparent z-10" />
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {[...clinics, ...clinics].map((c, i) => (
          <div class="font-display text-lg font-medium text-ink-secondary/80 hover:text-ink transition-colors">{c}</div>
        ))}
      </div>
    </div>
  </div>
</section>
