---
import { Image } from 'astro:assets';
import WhatsApp from '../icons/WhatsApp.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import telefono from '../../assets/img/telefono_conversacion.webp';
---

<section id="automation" class="py-12 lg:py-24 scroll-mt-16">
  <div class="container-wide">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-5">
        <div class="inline-flex items-center gap-2 rounded-full bg-accent/15 px-3 py-1.5 text-xs font-medium text-accent mb-5">
          <WhatsApp class="h-3.5 w-3.5" />
          Recordatorios automáticos por WhatsApp
        </div>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance">
          Haz que tus clientes vuelvan en el momento adecuado.
        </h2>
        <p class="mt-5 text-lg text-ink-secondary leading-relaxed">
          SaaslyVet usa el historial de cada paciente para enviar recordatorios, seguimientos y mensajes importantes por WhatsApp.
        </p>

        <ul class="mt-8 space-y-3">
          {["Confirmación automática de citas", "Recordatorios de vacunas y revisiones", "Seguimiento después de consultas", "Recuperación de pacientes inactivos"].map((b) => (
            <li class="flex items-start gap-3 text-sm text-ink">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brand" />
              {b}
            </li>
          ))}
        </ul>

        <a href="#pricing" class="group mt-8 inline-flex items-center gap-2 text-sm font-medium text-brand hover:gap-3 transition-all">
          Ver planes con automatizaciones
          <ArrowRight class="h-4 w-4" />
        </a>
      </div>

      <div class="lg:col-span-7">
        <div data-reveal="blur-in" class="relative mx-auto w-full max-w-[380px]">
          <!-- Efecto: glows decorativos a juego con el patrón del sitio -->
          <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-1/2 h-[82%] w-[82%] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-br from-brand/25 via-accent/15 to-transparent blur-3xl"></div>
            <div class="absolute right-2 top-10 h-40 w-40 rounded-full bg-accent/15 blur-3xl"></div>
            <div class="absolute bottom-8 left-4 h-40 w-40 rounded-full bg-brand/15 blur-3xl"></div>
          </div>

          <Image
            src={telefono}
            alt="Mano sosteniendo un teléfono con la conversación automática de WhatsApp de la clínica SaaslyVet"
            loading="lazy"
            decoding="async"
            class="phone-float relative block h-auto w-full"
            style="filter: drop-shadow(0 26px 34px rgba(20,40,35,0.22));"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .phone-float {
    animation: phone-float 6s ease-in-out infinite;
  }
  @keyframes phone-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .phone-float { animation: none; }
  }
</style>
