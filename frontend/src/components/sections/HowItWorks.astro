---
import Calendar from '../icons/Calendar.astro';
import Stethoscope from '../icons/Stethoscope.astro';
import Package from '../icons/Package.astro';
import CreditCard from '../icons/CreditCard.astro';
import WhatsApp from '../icons/WhatsApp.astro';
import FadeImage from '../ui/FadeImage.astro';
import atencionVeterinario from '../../assets/img/atencion_veterinario.png';

const steps = [
  { label: "Recepción", title: "La cita queda registrada", desc: "Luna llega a vacunación. El equipo encuentra su expediente y toda la información necesaria en segundos.", icon: Calendar, visual: "agenda" },
  { label: "Consulta", title: "El veterinario atiende", desc: "Accede al historial completo, registra hallazgos y deja todo listo para el siguiente paso.", icon: Stethoscope, visual: "soap" },
  { label: "Tratamiento", title: "Tratamiento e inventario conectados", desc: "Los productos utilizados quedan registrados y el inventario se actualiza automáticamente.", icon: Package, visual: "inventario" },
  { label: "Cobro", title: "Cobro sin duplicar trabajo", desc: "La recepción cobra usando la información generada durante la consulta.", icon: CreditCard, visual: "cobro" },
  { label: "Seguimiento", title: "El cliente vuelve", desc: "SaaslyVet mantiene la relación activa con recordatorios y mensajes automáticos por WhatsApp.", icon: WhatsApp, visual: "whatsapp" },
];
---

<section id="how" class="py-12 lg:py-24 bg-muted/30">
  <div class="container-wide">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center mb-8 lg:mb-16">
      <div class="max-w-2xl">
        <p class="text-sm font-medium text-brand mb-3">Cómo funciona</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance">
          Un flujo continuo, desde la cita hasta el seguimiento.
        </h2>
        <p class="mt-5 text-lg text-ink-secondary">
          Cada área de tu clínica trabaja conectada: recepción, veterinarios, inventario y comunicación con clientes.
        </p>
      </div>

      <div data-reveal="slide-left" class="relative isolate flex justify-center lg:justify-end">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 rounded-full bg-brand/10 blur-3xl"></div>
        <FadeImage
          src={atencionVeterinario}
          alt="Veterinario sonriendo mientras atiende a un perro y consulta el expediente en SaaslyVet"
          fade="all"
          intensity="medium"
          maxWidth="560px"
        />
      </div>
    </div>

    <div class="relative">
      <div class="hidden lg:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-line to-transparent" />

      <div class="space-y-8 lg:space-y-16">
        {steps.map((s, i) => (
          <div
            data-reveal={i % 2 === 0 ? "slide-right" : "slide-left"}
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${i % 2 === 1 ? "lg:[&>div:first-child]:order-2" : ""}`}
          >
            <div class={i % 2 === 1 ? "lg:text-right" : ""}>
              <div class={`flex items-center gap-3 mb-4 ${i % 2 === 1 ? "lg:justify-end" : ""}`}>
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-primary text-white shadow-soft">
                  <s.icon class="h-5 w-5" />
                </span>
                <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-ink-tertiary">{s.label}</span>
              </div>
              <h3 class="font-display text-2xl sm:text-3xl font-semibold text-ink tracking-tight">{s.title}</h3>
              <p class={`mt-3 text-base text-ink-secondary leading-relaxed max-w-md ${i % 2 === 1 ? "lg:ml-auto" : ""}`}>{s.desc}</p>
            </div>
            <div class="relative rounded-2xl border border-line bg-gradient-to-b from-white to-brand-soft/30 p-5">
              {s.visual === "agenda" && (
                <div class="space-y-4">
                  <div class="flex items-center gap-3 rounded-xl border border-line bg-white p-4">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand/10 text-brand">
                      <Calendar class="h-5 w-5" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-ink">Luna · Vacunación</p>
                      <p class="text-xs text-ink-secondary">14:30 · Dra. Vega · Sala 2</p>
                    </div>
                    <span class="text-[10px] font-medium uppercase tracking-wider px-2 py-1 rounded-md bg-brand-soft text-brand">Confirmada</span>
                  </div>
                </div>
              )}
              {s.visual === "soap" && (
                <div class="space-y-3">
                  <div class="flex items-start gap-2 text-xs text-ink-secondary">
                    <div class="h-7 w-7 shrink-0 rounded-md bg-muted flex items-center justify-center font-mono font-semibold text-ink text-[10px]">S</div>
                    <p class="leading-relaxed pt-0.5">Paciente presenta buen estado general. Se aplica vacuna séxtuple sin reacciones adversas.</p>
                  </div>
                  <div class="flex items-start gap-2 text-xs text-ink-secondary">
                    <div class="h-7 w-7 shrink-0 rounded-md bg-muted flex items-center justify-center font-mono font-semibold text-ink text-[10px]">P</div>
                    <p class="leading-relaxed pt-0.5">Próxima vacuna: refuerzo en 21 días. Control general en 6 meses.</p>
                  </div>
                </div>
              )}
              {s.visual === "inventario" && (
                <div class="space-y-2">
                  <div class="flex items-center justify-between rounded-lg bg-white border border-line px-3 py-2.5 text-sm">
                    <div class="flex items-center gap-2.5">
                      <Package class="h-4 w-4 text-ink-tertiary" />
                      <span class="text-ink">Vacuna Séxtuple</span>
                    </div>
                    <span class="text-xs text-ink-secondary">x1 · Stock: 30 → 29</span>
                  </div>
                </div>
              )}
              {s.visual === "cobro" && (
                <div class="rounded-xl border border-line bg-white p-4">
                  <div class="flex items-center justify-between text-sm mb-2">
                    <span class="text-ink">Consulta + Vacuna</span>
                    <span class="font-semibold text-ink">$750</span>
                  </div>
                  <div class="flex items-center justify-between text-xs text-ink-secondary">
                    <span>Método: Tarjeta</span>
                    <span class="text-success font-medium">Aprobado</span>
                  </div>
                </div>
              )}
              {s.visual === "whatsapp" && (
                <div class="max-w-[85%] rounded-2xl rounded-tl-sm bg-white border border-line px-3.5 py-3 shadow-sm">
                  <p class="text-xs text-ink/85 leading-relaxed">Hola Ana 👋 El refuerzo de vacuna de Luna está programado en 21 días. Te enviaremos un recordatorio.</p>
                  <p class="text-[10px] text-ink-tertiary mt-1.5 text-right">10:30 ✓✓</p>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
