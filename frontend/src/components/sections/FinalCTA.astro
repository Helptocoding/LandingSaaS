---
import { Image } from 'astro:assets';
import ArrowRight from '../icons/ArrowRight.astro';
import Calendar from '../icons/Calendar.astro';
import Check from '../icons/Check.astro';
import ctaEmocional from '../../assets/img/cta_emocional.webp';
---

<section class="py-12 lg:py-24">
  <div class="container-wide">
    <div data-reveal="zoom-out" class="relative overflow-hidden rounded-[2.5rem] border border-line bg-ink p-10 lg:p-16 text-center">
      <Image
        src={ctaEmocional}
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover object-right opacity-45"
      />
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-r from-ink via-ink/90 to-ink/40" />
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 15% 25%, hsl(158 40% 55%) 0%, transparent 25%), radial-gradient(circle at 85% 75%, hsl(16 75% 60%) 0%, transparent 25%)" />
      <div class="relative max-w-2xl mx-auto">
        <p class="text-sm font-medium text-surface/70 mb-3">Empieza hoy</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-surface text-balance">
          ¿Listo para organizar toda tu clínica veterinaria de una vez?
        </h2>
        <p class="mt-5 text-base sm:text-lg text-surface/75 leading-relaxed">
          Prueba SaaslyVet gratis 14 días. Sin tarjeta, sin instalaciones, con soporte en español desde el primer día.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <button
            data-testid="final-cta-trial-btn"
            data-cta-kind="trial"
            class="inline-flex items-center gap-2 bg-surface text-ink rounded-md px-6 py-3.5 font-medium hover:bg-surface/90 transition-colors group"
          >
            Registrate gratis
            <ArrowRight class="ml-2 h-4 w-4" />
          </button>
          <button
            data-testid="final-cta-demo-btn"
            data-cta-kind="demo"
            class="inline-flex items-center gap-2 bg-transparent border border-surface/30 text-surface rounded-md px-6 py-3.5 font-medium hover:bg-surface/10 transition-colors"
          >
            <Calendar class="mr-2 h-4 w-4" />
            Ver demo en vivo
          </button>
        </div>
        <ul class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-surface/60">
          {["Sin permanencia", "Cancela cuando quieras", "Acceso desde cualquier dispositivo", "Soporte durante la configuración"].map((t) => (
            <li class="flex items-center gap-1.5">
              <Check class="h-3.5 w-3.5 text-surface/50" />
              {t}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script type="module">
  import { ctaToast } from '../../lib/cta.js';
  document.querySelectorAll('[data-cta-kind]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      ctaToast(this.getAttribute('data-cta-kind'));
    });
  });
</script>
