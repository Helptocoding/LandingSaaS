---
/**
 * MarketingDashboard — versión "sesión fotográfica" del panel de SaaSlyVet.
 *
 * NO se usa en la aplicación real. Único propósito: renderizar un panel premium,
 * limpio y legible para capturarlo en alta resolución (4K) e insertarlo dentro
 * de la tablet del Hero. Prioriza claridad, aire y jerarquía sobre fidelidad.
 *
 * Ver README.md en esta carpeta para el detalle de qué se simplificó y por qué.
 */
import BarChart3 from '../icons/BarChart3.astro';
import CalendarDays from '../icons/CalendarDays.astro';
import PawPrint from '../icons/PawPrint.astro';
import FileText from '../icons/FileText.astro';
import Package from '../icons/Package.astro';
import Stethoscope from '../icons/Stethoscope.astro';
import CreditCard from '../icons/CreditCard.astro';
import Bell from '../icons/Bell.astro';
import Search from '../icons/Search.astro';
import Syringe from '../icons/Syringe.astro';
import Check from '../icons/Check.astro';
import Clock from '../icons/Clock.astro';
import TrendingUp from '../icons/TrendingUp.astro';
import ArrowRight from '../icons/ArrowRight.astro';

export interface Props {
  /**
   * 'standalone' → tarjeta con chrome propio (borde/redondeo), para la página de captura.
   * 'hero'       → sin chrome y a tamaño fijo (1440×1012, relación de la pantalla de la
   *                tablet) para renderizarse DENTRO del marco del Hero y escalarse por CSS.
   */
  variant?: 'standalone' | 'hero';
  /** Reservado para animaciones internas; hoy el panel es estático (la vida la da el Hero). */
  animated?: boolean;
  /** Compacta ligeramente el espaciado (útil cuando el panel se reduce). */
  compact?: boolean;
}

const { variant = 'standalone', animated = true, compact = false } = Astro.props;
const isHero = variant === 'hero';
const px = compact ? 'px-10' : 'px-12';

const nav = [
  { label: 'Dashboard', icon: BarChart3, active: true },
  { label: 'Agenda', icon: CalendarDays, active: false },
  { label: 'Pacientes', icon: PawPrint, active: false },
  { label: 'Historial clínico', icon: FileText, active: false },
  { label: 'Inventario', icon: Package, active: false },
];

const stats = [
  { label: 'Consultas hoy', value: '12', icon: Stethoscope, delta: '+3 vs ayer', tone: 'up' },
  { label: 'Pacientes', value: '248', icon: PawPrint, delta: '+8 este mes', tone: 'neutral' },
  { label: 'Ventas del día', value: '$8,450', icon: CreditCard, delta: '+12%', tone: 'up' },
  { label: 'Recordatorios', value: '5', icon: Bell, delta: 'enviados hoy', tone: 'muted' },
];

const agenda = [
  { time: '09:00', name: 'Luna', breed: 'Golden Retriever', type: 'Vacunación', icon: Syringe, status: 'Confirmada', tone: 'success' },
  { time: '11:00', name: 'Rocky', breed: 'Bulldog Francés', type: 'Consulta', icon: Stethoscope, status: 'En espera', tone: 'warning' },
  { time: '13:00', name: 'Mía', breed: 'Siamés', type: 'Desparasitación', icon: Check, status: 'Confirmada', tone: 'success' },
];

// Ingresos de la semana — solo decorativo. Domingo es "hoy" (destacado).
const week = [
  { d: 'Lun', h: 52 },
  { d: 'Mar', h: 63 },
  { d: 'Mié', h: 48 },
  { d: 'Jue', h: 71 },
  { d: 'Vie', h: 84 },
  { d: 'Sáb', h: 66 },
  { d: 'Hoy', h: 92, today: true },
];

const estado = [
  { label: 'En consulta', value: '2', dot: 'bg-accent' },
  { label: 'En espera', value: '3', dot: 'bg-warning' },
  { label: 'Completadas', value: '8', dot: 'bg-success' },
];
---

<div
  class:list={[
    'mkt-dash flex w-full overflow-hidden bg-page font-sans text-ink antialiased',
    isHero ? 'h-full' : 'rounded-[26px] border border-line',
  ]}
  style={isHero ? 'width:1440px;height:1012px' : ''}
>

  <!-- ═══════════ Sidebar (identidad SaaSlyVet: verde marca) ═══════════ -->
  <aside class="flex w-[264px] shrink-0 flex-col bg-brand px-5 py-7 text-white">
    <!-- Marca -->
    <div class="flex items-center gap-2.5 px-2">
      <span class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl bg-surface/12 ring-1 ring-white/15">
        <img src="/iconosaaslyvet.ico" alt="" class="h-6 w-6 scale-[2]" />
      </span>
      <span class="font-display text-[19px] font-semibold tracking-tight">SaaslyVet</span>
    </div>

    <!-- Navegación -->
    <nav class="mt-9 flex flex-col gap-1.5">
      <p class="px-3 pb-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-white/45">Menú</p>
      {nav.map((item) => (
        <a
          href="#"
          class:list={[
            'flex items-center gap-3 rounded-xl px-3 py-3 text-[15px] font-medium transition-colors',
            item.active ? 'bg-surface/15 text-white shadow-sm' : 'text-white/70 hover:bg-surface/8 hover:text-white',
          ]}
        >
          <item.icon class="h-[19px] w-[19px] shrink-0" />
          <span>{item.label}</span>
          {item.active && <span class="ml-auto h-1.5 w-1.5 rounded-full bg-brand-accent" />}
        </a>
      ))}
    </nav>

    <!-- Clínica -->
    <div class="mt-auto flex items-center gap-3 rounded-xl bg-surface/8 px-3 py-3 ring-1 ring-white/10">
      <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-accent text-[13px] font-semibold text-brand">VS</span>
      <div class="min-w-0 leading-tight">
        <p class="truncate text-[14px] font-semibold">Clínica VetSalud</p>
        <p class="text-[12px] text-white/55">Plan Pro</p>
      </div>
    </div>
  </aside>

  <!-- ═══════════ Contenido principal ═══════════ -->
  <main class="flex min-w-0 flex-1 flex-col">

    <!-- Topbar -->
    <header class:list={['flex items-center justify-between gap-6 pt-8 pb-6', px]}>
      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-ink-tertiary">Martes · 2 de julio</p>
        <h1 class="mt-1.5 font-display text-[30px] font-semibold tracking-tight text-ink">Resumen de hoy</h1>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex h-11 w-72 items-center gap-2.5 rounded-xl border border-line bg-surface px-4 text-ink-tertiary">
          <Search class="h-[18px] w-[18px]" />
          <span class="text-[14px]">Buscar paciente…</span>
        </div>
        <span class="relative flex h-11 w-11 items-center justify-center rounded-xl border border-line bg-surface text-ink-secondary">
          <Bell class="h-[19px] w-[19px]" />
          <span class="absolute right-2.5 top-2.5 h-2 w-2 rounded-full bg-accent ring-2 ring-surface" />
        </span>
        <span class="flex h-11 w-11 items-center justify-center rounded-full bg-brand text-[14px] font-semibold text-white">DG</span>
      </div>
    </header>

    <div
      class:list={[
        'flex flex-col pb-9',
        px,
        compact ? 'gap-6' : 'gap-7',
        isHero && 'flex-1 justify-between',
      ]}
    >

      <!-- Fila superior: 4 tarjetas grandes -->
      <section class="grid grid-cols-4 gap-7">
        {stats.map((s) => (
          <div class="rounded-2xl border border-line bg-surface p-6 shadow-soft">
            <div class="flex items-center justify-between">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-soft text-brand">
                <s.icon class="h-6 w-6" />
              </span>
              {s.tone === 'up' && (
                <span class="flex items-center gap-1 rounded-full bg-success/10 px-2.5 py-1 text-[12px] font-semibold text-success">
                  <TrendingUp class="h-3.5 w-3.5" />{s.delta}
                </span>
              )}
              {s.tone === 'neutral' && (
                <span class="rounded-full bg-brand-soft px-2.5 py-1 text-[12px] font-semibold text-brand">{s.delta}</span>
              )}
              {s.tone === 'muted' && (
                <span class="rounded-full bg-muted px-2.5 py-1 text-[12px] font-medium text-ink-tertiary">{s.delta}</span>
              )}
            </div>
            <p class="mt-5 text-[14px] text-ink-secondary">{s.label}</p>
            <p class="mt-1 font-display text-[34px] font-semibold leading-none tracking-tight text-ink">{s.value}</p>
          </div>
        ))}
      </section>

      <!-- Fila media: Agenda (2/3) + widgets (1/3) -->
      <section class="grid grid-cols-3 items-start gap-7">

        <!-- Agenda -->
        <div class="col-span-2 rounded-2xl border border-line bg-surface p-7 shadow-soft">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="font-display text-[19px] font-semibold tracking-tight text-ink">Agenda de hoy</h2>
              <p class="mt-0.5 text-[13px] text-ink-tertiary">3 consultas programadas</p>
            </div>
            <a href="#" class="flex items-center gap-1.5 text-[14px] font-medium text-brand">
              Ver todo <ArrowRight class="h-4 w-4" />
            </a>
          </div>

          <div class="mt-6 flex flex-col gap-4">
            {agenda.map((a) => (
              <div class="flex items-center gap-4 rounded-xl border border-line/70 bg-page/60 px-5 py-5">
                <div class="flex w-16 shrink-0 flex-col items-center">
                  <span class="font-display text-[17px] font-semibold text-ink">{a.time}</span>
                </div>
                <span class="h-11 w-px shrink-0 bg-line" />
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand-soft text-brand">
                  <a.icon class="h-[22px] w-[22px]" />
                </span>
                <div class="min-w-0 flex-1">
                  <p class="text-[16px] font-semibold text-ink">{a.name}</p>
                  <p class="text-[13px] text-ink-secondary">{a.breed} · {a.type}</p>
                </div>
                <span
                  class:list={[
                    'shrink-0 rounded-full px-3 py-1.5 text-[12px] font-semibold',
                    a.tone === 'success' ? 'bg-success/10 text-success' : 'bg-warning/15 text-[hsl(32_80%_40%)]',
                  ]}
                >
                  {a.status}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Widgets -->
        <div class="flex flex-col gap-7">

          <!-- Próximo turno -->
          <div class="rounded-2xl border border-line bg-gradient-primary p-6 text-white shadow-soft">
            <div class="flex items-center gap-2 text-[12px] font-semibold uppercase tracking-[0.16em] text-white/70">
              <Clock class="h-4 w-4" /> Próximo turno
            </div>
            <div class="mt-4 flex items-center gap-4">
              <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-surface/15 ring-1 ring-white/20">
                <PawPrint class="h-7 w-7" />
              </span>
              <div>
                <p class="font-display text-[22px] font-semibold leading-tight">Rocky</p>
                <p class="text-[14px] text-white/75">Consulta general</p>
              </div>
            </div>
            <div class="mt-5 flex items-center justify-between border-t border-white/15 pt-4 text-[14px]">
              <span class="text-white/75">11:00 · Dr. García</span>
              <span class="rounded-full bg-surface/15 px-3 py-1 font-semibold">en 25 min</span>
            </div>
          </div>

          <!-- Estado de la clínica -->
          <div class="flex flex-col rounded-2xl border border-line bg-surface p-7 shadow-soft">
            <h2 class="font-display text-[19px] font-semibold tracking-tight text-ink">Estado de la clínica</h2>

            <div class="mt-6 flex flex-col gap-5">
              {estado.map((e) => (
                <div class="flex items-center gap-3">
                  <span class:list={['h-2.5 w-2.5 rounded-full', e.dot]} />
                  <span class="flex-1 text-[15px] text-ink-secondary">{e.label}</span>
                  <span class="font-display text-[18px] font-semibold text-ink">{e.value}</span>
                </div>
              ))}
            </div>

            <div class="mt-6 border-t border-line pt-5">
              <div class="flex items-center justify-between text-[13px] text-ink-tertiary">
                <span>Citas completadas</span>
                <span class="font-semibold text-ink">8 / 12</span>
              </div>
              <div class="mt-2.5 h-2.5 overflow-hidden rounded-full bg-muted">
                <div class="h-full rounded-full bg-brand" style="width:66.7%" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Fila inferior: gráfico ancho (decorativo) -->
      <section class="rounded-2xl border border-line bg-surface p-7 shadow-soft">
        <div class="flex items-end justify-between">
          <div>
            <h2 class="font-display text-[19px] font-semibold tracking-tight text-ink">Ingresos de la semana</h2>
            <p class="mt-1 font-display text-[26px] font-semibold tracking-tight text-ink">$42,180</p>
          </div>
          <span class="flex items-center gap-1.5 rounded-full bg-success/10 px-3 py-1.5 text-[13px] font-semibold text-success">
            <TrendingUp class="h-4 w-4" /> +18% vs semana pasada
          </span>
        </div>

        <div class="mt-6 flex h-28 items-end justify-between gap-6">
          {week.map((b) => (
            <div class="flex flex-1 justify-center">
              <div
                class="w-full max-w-[72px] rounded-t-lg"
                style={`height:${b.h}px; background:${b.today ? 'hsl(160 35% 28%)' : 'hsl(158 40% 55% / 0.30)'}`}
              />
            </div>
          ))}
        </div>
        <div class="mt-3 flex justify-between gap-6">
          {week.map((b) => (
            <span class:list={['flex-1 text-center text-[13px]', b.today ? 'font-semibold text-ink' : 'text-ink-tertiary']}>{b.d}</span>
          ))}
        </div>
      </section>
    </div>
  </main>
</div>
