---
// Layout de artículo. Envuelve Base (SEO + observer + modales) igual que
// LegalLayout, y añade lo propio del blog: JSON-LD (BlogPosting + BreadcrumbList
// + FAQPage), OG article, TOC, FAQ, CTA, relacionados y navegación prev/next.
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import JsonLD from '../components/seo/JsonLD.astro';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import Breadcrumbs from '../components/blog/Breadcrumbs.astro';
import ArticleMeta from '../components/blog/ArticleMeta.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import RelatedArticles from '../components/blog/RelatedArticles.astro';
import PostNav from '../components/blog/PostNav.astro';
import BlogCTA from '../components/blog/BlogCTA.astro';
import ArrowRight from '../components/icons/ArrowRight.astro';
import { getCategory, getAuthor, resolveCta, isoDate, type PillarCategory } from '../data/blog';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  post: CollectionEntry<'blog'>;
  headings: Heading[];
  readingTime: number;
  related?: CollectionEntry<'blog'>[];
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { post, headings, readingTime, related = [], prev, next } = Astro.props;
const { data } = post;

const category = getCategory(data.category) as PillarCategory;
const author = getAuthor(data.author);
const authorHref = author ? `/blog/autor/${author.id}/` : undefined;
const reviewer = data.reviewer ? getAuthor(data.reviewer) : undefined;

// CTA contextual: override del frontmatter sobre el defaultCta de la categoría.
const cta = resolveCta(category, {
  kind: data.ctaKind,
  title: data.ctaTitle,
  text: data.ctaText,
  label: data.ctaLabel,
});

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.saaslyvet.com';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imagePath = data.image ?? '/og-image.png';
const imageUrl = imagePath.startsWith('http') ? imagePath : `${siteUrl}${imagePath}`;
const publishedISO = isoDate(data.publishDate);
const modifiedISO = isoDate(data.updatedDate ?? data.publishDate);
const categoryUrl = `${siteUrl}/blog/categoria/${category.slug}/`;

// E-E-A-T: autor persona real → Person con sameAs; equipos → Organization.
const authorSchema =
  author && author.id === 'felipe-diaz'
    ? {
        '@type': 'Person',
        name: author.name,
        jobTitle: author.role,
        description: author.bio,
        url: `${siteUrl}/blog/autor/${author.id}`,
        ...(author.sameAs && author.sameAs.length ? { sameAs: author.sameAs } : {}),
      }
    : { '@type': 'Organization', name: author?.name ?? 'SaaslyVet', url: siteUrl };

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  image: imageUrl,
  datePublished: publishedISO,
  dateModified: modifiedISO,
  author: authorSchema,
  publisher: {
    '@type': 'Organization',
    name: 'SaaslyVet',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo-512.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  ...(data.keywords.length ? { keywords: data.keywords.join(', ') } : {}),
  ...(reviewer
    ? {
        reviewedBy: {
          '@type': 'Person',
          name: reviewer.name,
          ...(reviewer.credentials ? { description: reviewer.credentials } : {}),
          ...(reviewer.sameAs && reviewer.sameAs.length ? { sameAs: reviewer.sameAs } : {}),
        },
      }
    : {}),
  articleSection: category.name,
  inLanguage: 'es-MX',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: category.name, item: categoryUrl },
    { '@type': 'ListItem', position: 4, name: data.title, item: pageUrl },
  ],
};

const faqSchema = data.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---

<Base
  title={`${data.title} | SaaslyVet`}
  description={data.description}
  canonical={pageUrl}
  image={imagePath}
  ogType="article"
  jsonld={articleSchema}
>
  <Fragment slot="head">
    <JsonLD schema={breadcrumbSchema} />
    {faqSchema && <JsonLD schema={faqSchema} />}
    <link rel="alternate" type="application/rss+xml" title="Blog de SaaslyVet" href="/blog/rss.xml" />
    <meta property="article:published_time" content={publishedISO} />
    {data.updatedDate && <meta property="article:modified_time" content={modifiedISO} />}
    <meta property="article:section" content={category.name} />
    {data.keywords.map((k) => <meta property="article:tag" content={k} />)}
  </Fragment>

  <Header />

  <main id="main" class="pt-16">
    <article>
      <!-- Encabezado -->
      <header class="border-b border-line">
        <div class="container-narrow py-10 lg:py-14">
          <Breadcrumbs
            items={[
              { label: 'Inicio', href: '/' },
              { label: 'Blog', href: '/blog/' },
              { label: category.name, href: `/blog/categoria/${category.slug}/` },
              { label: data.title },
            ]}
          />

          <a
            href={`/blog/categoria/${category.slug}/`}
            class="mt-6 inline-flex text-xs font-semibold uppercase tracking-[0.16em] text-brand transition-colors hover:text-brand-hover"
          >
            {category.name}
          </a>

          <h1 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink text-balance lg:text-[2.6rem] lg:leading-[1.1]">
            {data.title}
          </h1>

          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-secondary text-balance">
            {data.description}
          </p>

          <div class="mt-6">
            <ArticleMeta
              author={author?.name ?? 'SaaslyVet'}
              authorHref={authorHref}
              date={data.publishDate}
              updated={data.updatedDate}
              readingTime={readingTime}
            />
            {reviewer && (
              <p class="mt-2 text-sm text-ink-tertiary">
                Revisado por{' '}
                <a href={`/blog/autor/${reviewer.id}/`} class="font-medium text-ink-secondary hover:text-ink">
                  {reviewer.name}
                </a>
                {reviewer.credentials ? `, ${reviewer.credentials}` : ''}
              </p>
            )}
          </div>
        </div>
      </header>

      <!-- Cuerpo: TOC + prosa -->
      <div class="container-wide py-10 lg:py-16">
        <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 lg:grid-cols-[220px_minmax(0,720px)] lg:gap-12 lg:justify-center">
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents headings={headings} />
            </div>
          </aside>

          <div class="min-w-0">
            <div class="prose">
              <slot />
            </div>

            {
              data.faq.length > 0 && (
                <section class="mt-12 border-t border-line pt-10" aria-labelledby="faq-heading">
                  <h2 id="faq-heading" class="font-display text-2xl font-semibold tracking-tight text-ink">
                    Preguntas frecuentes
                  </h2>
                  <div class="mt-6 divide-y divide-line border-y border-line">
                    {data.faq.map((f) => (
                      <details class="group py-4">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-ink">
                          {f.q}
                          <span class="text-ink-tertiary transition-transform group-open:rotate-45">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                          </span>
                        </summary>
                        <p class="mt-3 leading-relaxed text-ink-secondary">{f.a}</p>
                      </details>
                    ))}
                  </div>
                </section>
              )
            }

            <!-- Pertenencia al clúster (interlinking hacia la página pilar) -->
            <div class="mt-12 rounded-xl border border-line bg-muted/30 p-5 text-sm">
              <p class="text-ink-secondary">
                Esta guía forma parte del clúster
                <a
                  href={`/blog/categoria/${category.slug}/`}
                  class="inline-flex items-center gap-1 font-medium text-brand underline underline-offset-2 hover:text-brand-hover"
                >
                  {category.name}
                  <ArrowRight class="h-3.5 w-3.5" />
                </a>.
              </p>
            </div>

            <!-- CTA contextual -->
            <div class="mt-10">
              <BlogCTA kind={cta.kind} title={cta.title} text={cta.text} label={cta.label} />
            </div>
          </div>
        </div>
      </div>
    </article>

    <RelatedArticles
      posts={related}
      title={`Más sobre ${category.name}`}
      subtitle={category.intro}
    />

    <div class="container-wide pb-16">
      <PostNav prev={prev} next={next} />
    </div>
  </main>

  <Footer />
</Base>

<style is:global>
  /* Tipografía de lectura del artículo. Scope .prose para no filtrar al resto. */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: hsl(var(--ink-secondary));
  }
  .prose > * + * {
    margin-top: 1.25em;
  }
  .prose h2 {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: 1.6rem;
    line-height: 1.25;
    color: hsl(var(--ink));
    margin-top: 2.2em;
    margin-bottom: 0.2em;
    scroll-margin-top: 6rem;
  }
  .prose h3 {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-weight: 600;
    letter-spacing: -0.015em;
    font-size: 1.2rem;
    line-height: 1.3;
    color: hsl(var(--ink));
    margin-top: 1.8em;
    margin-bottom: 0.1em;
    scroll-margin-top: 6rem;
  }
  .prose p {
    color: hsl(var(--ink-secondary));
  }
  .prose a {
    color: hsl(var(--brand));
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }
  .prose a:hover {
    color: hsl(var(--brand-hover));
  }
  .prose strong {
    color: hsl(var(--ink));
    font-weight: 600;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.4em;
  }
  .prose ul {
    list-style: disc;
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li {
    margin-top: 0.5em;
    padding-left: 0.25em;
  }
  .prose li::marker {
    color: hsl(var(--brand));
  }
  .prose blockquote {
    border-left: 3px solid hsl(var(--brand));
    padding: 0.2em 0 0.2em 1.25em;
    color: hsl(var(--ink));
    font-style: italic;
  }
  .prose blockquote p {
    color: hsl(var(--ink));
  }
  .prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: hsl(var(--muted));
    padding: 0.15em 0.4em;
    border-radius: 0.35rem;
    color: hsl(var(--ink));
  }
  .prose pre {
    background: hsl(var(--muted));
    border: 1px solid hsl(var(--line));
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
  }
  .prose img {
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--line));
  }
  .prose hr {
    border: none;
    border-top: 1px solid hsl(var(--line));
    margin: 2.5em 0;
  }
  .prose h2 + *,
  .prose h3 + * {
    margin-top: 0.6em;
  }
</style>
